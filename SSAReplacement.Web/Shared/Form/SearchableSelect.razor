@namespace SSAReplacement.Web.Shared.Form
@implements IDisposable
@typeparam TItem

@inject IJSRuntime JSRuntime

<div class="typeahead-wrap" @ref="_rootRef">
    <SearchBar Value="@_filterText"
               ValueChanged="OnFilterChanged"
               OnFocus="ShowDropdown"
               Placeholder="@Placeholder"
               AriaLabel="@AriaLabel" />

    <div class="dropdown-list @(_dropdownVisible ? "" : "hidden")">
        @foreach (var item in FilteredItems)
        {
            var itemValue = ValueSelector(item);
            var itemText = TextSelector(item);

            <div class="dropdown-option"
                 @onclick="() => SelectItem(itemValue, itemText)"
                 @onclick:stopPropagation="true">
                @itemText
            </div>
        }
    </div>
</div>

@code {
    [Parameter]
    public IEnumerable<TItem>? Items { get; set; }

    [Parameter]
    public int? Value { get; set; }

    [Parameter]
    public EventCallback<int?> ValueChanged { get; set; }

    [Parameter]
    public Func<TItem, int> ValueSelector { get; set; } = null!;

    [Parameter]
    public Func<TItem, string> TextSelector { get; set; } = null!;

    [Parameter]
    public string? Placeholder { get; set; }

    [Parameter]
    public string? AriaLabel { get; set; }

    private string _filterText = "";
    private bool _dropdownVisible;

    private IEnumerable<TItem> FilteredItems
    {
        get
        {
            var list = Items?.ToList() ?? new List<TItem>();
            if (string.IsNullOrWhiteSpace(_filterText))
                return list;
            var q = _filterText.Trim();
            return list.Where(x => TextSelector(x).Contains(q, StringComparison.OrdinalIgnoreCase));
        }
    }

    protected override void OnParametersSet()
    {
        if (Value is int id && Items != null)
        {
            var selected = Items.FirstOrDefault(x => ValueSelector(x) == id);
            _filterText = selected is not null ? TextSelector(selected) : "";
        }
        else
            _filterText = "";
    }

    private async Task OnFilterChanged(string? value)
    {
        _filterText = value ?? "";
        _dropdownVisible = true;
        if (Value.HasValue)
            await ValueChanged.InvokeAsync(null);

        await InvokeAsync(StateHasChanged);
    }

    private async Task SelectItem(int id, string text)
    {
        _filterText = text;
        _dropdownVisible = false;
        await ValueChanged.InvokeAsync(id);
        StateHasChanged();
    }

    private void ShowDropdown() => _dropdownVisible = true;

    private ElementReference _rootRef;
    private DotNetObjectReference<SearchableSelect<TItem>>? _dotNetRef;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        //Javascript helper to hide the dropdown if the user clicks anywhere outside the element
        if (_dropdownVisible && _dotNetRef is null)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            await JSRuntime.InvokeVoidAsync("searchableSelect.registerClickOutside", _rootRef, _dotNetRef);
        }
        else if (!_dropdownVisible)
        {
            _dotNetRef?.Dispose();
            _dotNetRef = null;
        }
    }

    [JSInvokable]
    public void CloseDropdown()
    {
        if (!_dropdownVisible) 
            return;

        _dropdownVisible = false;
        _dotNetRef?.Dispose();
        _dotNetRef = null;

        InvokeAsync(StateHasChanged);
    }

    public void Dispose() => _dotNetRef?.Dispose();
}

@page "/executables/{Id:int}"
@using SSAReplacement.Web.Shared.Form
@using SSAReplacement.Web.Shared.Pill
@using SSAReplacement.Web.Client
@inject SsaApiClient Api
@inject NavigationManager Nav

<PageTitle>@(_executable?.Name ?? "Executable")</PageTitle>

@if (_loading && _executable is null && _error is null)
{
    <div class="status loading">Loading…</div>
}
else if (_executable is null)
{
    <p class="empty">Executable not found. <NavLink href="/executables">Back to Executables</NavLink></p>
}
else
{
    @if (_error is not null)
    {
        <div class="status error">@_error</div>
    }

    <header class="page-header">
        <nav class="breadcrumb" aria-label="Breadcrumb">
            <NavLink href="/executables">Executables</NavLink>
            <span class="breadcrumb-sep" aria-hidden="true">&gt;</span>
            <span class="breadcrumb-current">@_executable.Name</span>
        </nav>
        <div class="page-header-actions">
            <button type="button" @onclick="OpenUploadModal">Upload version</button>
        </div>
    </header>

    <div class="grid">
        <div class="row">
            <section class="col col-span-6 job-detail-section paper">
                <h2 class="section-heading">Details</h2>
                <dl class="detail-list">
                    <dt>Name</dt>
                    <dd>@(_executable.Name ?? "—")</dd>
                    <dt>Created</dt>
                    <dd>@_executable.CreatedAt.ToTimeAgo()</dd>
                </dl>
            </section>

            <section class="col col-span-6 job-detail-section paper">
            <h2 class="section-heading">Versions</h2>
            @if (!_executable.Versions.Any())
            {
                <p class="empty">No versions yet.</p>
            }
            else
            {
                <table class="table">
                    <thead>
                        <tr>
                            <th>Version</th>
                            <th>Entry point DLL</th>
                            <th>Uploaded</th>
                            <th>Active</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var version in _executable.Versions)
                        {
                            <tr>
                                <td>@version.Version</td>
                                <td>@version.EntryPointDll</td>
                                <td>@version.UploadedAt.ToTimeAgo()</td>
                                <td><Pill Color="@(version.IsActive ? PillColor.Success : PillColor.Muted)" Text="@(version.IsActive ? "Active" : "Inactive")" /></td>
                                <td>
                                    @if (!version.IsActive)
                                    {
                                        <button type="button" class="btn-secondary" disabled="@_activatingVersionId.HasValue" @onclick="() => SetActiveVersion(version.Id)">Set active</button>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            </section>
        </div>
    </div>

    <Modal Title="Upload version" Visible="_uploadModalVisible" OnClose="CloseUploadModal">
        <div class="form">
            <FormField Label="File" Required ErrorMessage="@_uploadFileError" InputId="upload-version-file">
                <InputFile id="upload-version-file" OnChange="OnUploadFileChanged" accept=".zip" aria-describedby="upload-version-file-error" aria-invalid="@(!string.IsNullOrEmpty(_uploadFileError))" />
                @if (_selectedFile is not null)
                {
                    <span>@_selectedFile.Name</span>
                }
            </FormField>
            <FormField Label="Entry point DLL" Required ErrorMessage="@_uploadEntryPointError" InputId="upload-entrypoint">
                <input id="upload-entrypoint" type="text" value="@_uploadEntryPointDll" @oninput="OnUploadEntryPointChanged" placeholder="e.g. MyApp.dll" aria-describedby="upload-entrypoint-error" aria-invalid="@(!string.IsNullOrEmpty(_uploadEntryPointError))" />
            </FormField>
            <div class="actions">
                <button type="button" @onclick="SubmitUpload" disabled="@_uploadSubmitting">Upload</button>
                <button type="button" class="btn-secondary" @onclick="CloseUploadModal">Cancel</button>
            </div>
        </div>
    </Modal>
}

@code {
    [Parameter]
    public int Id { get; set; }

    private const long MaxFileSize = 50 * 1024 * 1024; // 50 MB

    private SSAReplacement.Web.Client.ExecutableDetail? _executable;
    private bool _loading = true;
    private string? _error;

    private bool _uploadModalVisible;
    private IBrowserFile? _selectedFile;
    private string _uploadEntryPointDll = "";
    private string? _uploadFileError;
    private string? _uploadEntryPointError;
    private bool _uploadSubmitting;

    private int? _activatingVersionId;

    protected override async Task OnParametersSetAsync()
    {
        if (Id > 0)
            await LoadData();
    }

    private async Task LoadData()
    {
        _loading = true;
        _error = null;
        try
        {
            _executable = await Api.GetExecutableAsync(Id);
        }
        catch (Exception ex)
        {
            _error = "Failed to load: " + ex.Message;
            _executable = null;
        }
        finally
        {
            _loading = false;
        }
    }

    private void OpenUploadModal()
    {
        _uploadModalVisible = true;
        _selectedFile = null;
        _uploadEntryPointDll = "";
        _uploadFileError = null;
        _uploadEntryPointError = null;
    }

    private void CloseUploadModal()
    {
        _uploadModalVisible = false;
        _selectedFile = null;
        _uploadEntryPointDll = "";
        _uploadFileError = null;
        _uploadEntryPointError = null;
    }

    private void OnUploadFileChanged(InputFileChangeEventArgs e)
    {
        _selectedFile = e.File;
        _uploadFileError = null;
    }

    private void OnUploadEntryPointChanged(ChangeEventArgs e)
    {
        _uploadEntryPointDll = e.Value?.ToString() ?? "";
        _uploadEntryPointError = null;
    }

    private async Task SubmitUpload()
    {
        _uploadFileError = null;
        _uploadEntryPointError = null;

        var hasError = false;
        if (_selectedFile is null)
        {
            _uploadFileError = "Select a file.";
            hasError = true;
        }
        if (string.IsNullOrWhiteSpace(_uploadEntryPointDll))
        {
            _uploadEntryPointError = "Enter the entry point DLL.";
            hasError = true;
        }
        if (hasError)
        {
            await InvokeAsync(StateHasChanged);
            return;
        }

        _uploadSubmitting = true;
        try
        {
            await using var stream = _selectedFile!.OpenReadStream(MaxFileSize);
            await Api.UploadExecutableVersionAsync(Id, stream, _selectedFile.Name, _uploadEntryPointDll.Trim());
            CloseUploadModal();
            await LoadData();
        }
        catch (Exception ex)
        {
            _uploadFileError = ex.Message;
        }
        finally
        {
            _uploadSubmitting = false;
        }
    }

    private async Task SetActiveVersion(int versionId)
    {
        if (_executable is null) return;
        _activatingVersionId = versionId;
        try
        {
            await Api.ActivateExecutableVersionAsync(Id, versionId);
            await LoadData();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _activatingVersionId = null;
        }
    }
}

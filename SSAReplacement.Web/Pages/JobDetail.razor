@page "/jobs/{Id:int}"
@using SSAReplacement.Web.Shared.Form
@using SSAReplacement.Web.Shared.Pill
@using SSAReplacement.Web.Client
@inject SsaApiClient Api
@inject NavigationManager Nav

<PageTitle>@(_job?.Name ?? "Job")</PageTitle>

@if (_loading && _job is null && _error is null)
{
    <div class="status loading">Loading…</div>
}
else if (_job is null)
{
    <p class="empty">Job not found. <NavLink href="/jobs">Back to Jobs</NavLink></p>
}
else
{
    @if (_error is not null)
    {
        <div class="status error">@_error</div>
    }
    @if (_triggerMessage is not null)
    {
        <div class="status">@_triggerMessage</div>
    }
    @if (_triggerError is not null)
    {
        <div class="status error">@_triggerError</div>
    }

    <header class="page-header">
        <nav class="breadcrumb" aria-label="Breadcrumb">
            <NavLink href="/jobs">Jobs</NavLink>
            <span class="breadcrumb-sep" aria-hidden="true">&gt;</span>
            <span class="breadcrumb-current">@_job.Name</span>
        </nav>
        <div class="page-header-actions">
            <button type="button" disabled="@_triggering" @onclick="RunNow">Run now</button>
        </div>
    </header>

    <div class="grid">
        <div class="row">
            <section class="col col-span-6 job-detail-section paper">
                <h2 class="section-heading">Details</h2>
                <dl class="detail-list">
                    <dt>Name</dt>
                    <dd>@_job.Name</dd>
                    <dt>Executable</dt>
                    <dd>@(_job.ExecutableName ?? "—")</dd>
                    <dt>Enabled</dt>
                    <dd><Pill Color="@(_job.IsEnabled ? PillColor.Success : PillColor.Muted)" Text="@(_job.IsEnabled ? "Enabled" : "Disabled")" /></dd>
                    <dt>Created</dt>
                    <dd>@_job.CreatedAt.ToTimeAgo()</dd>
                </dl>
            </section>

            <section class="col col-span-6 job-detail-section paper">
                <div class="section-header">
                    <h2 class="section-heading">Schedules</h2>
                    <div class="section-header-actions">
                        <button type="button" @onclick="OpenAddScheduleModal">Add schedule</button>
                    </div>
                </div>
                @if (!_job.Schedules.Any())
                {
                    <p class="empty">No schedules assigned.</p>
                }
                else
                {
                    <table class="table">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Cron</th>
                                <th>Enabled</th>
                                <th>Created</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var schedule in _job.Schedules)
                            {
                                <tr>
                                    <td>@(schedule.Name ?? "—")</td>
                                    <td>
                                        @schedule.CronExpression
                                        <span class="cron-description-hint" title="@CronDescription.GetDescription(schedule.CronExpression)" aria-label="Schedule description"><i class="bi bi-question-circle"></i></span>
                                    </td>
                                    <td><Pill Color="@(schedule.IsEnabled ? PillColor.Success : PillColor.Muted)" Text="@(schedule.IsEnabled ? "Enabled" : "Disabled")" /></td>
                                    <td>@schedule.CreatedAt.ToTimeAgo()</td>
                                    <td>
                                        <button type="button" class="btn-secondary" @onclick="() => RemoveSchedule(schedule.Id)">Remove</button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </section>
        </div>

        <div class="row">
            <section class="col col-span-12 job-detail-section paper">
                <h2 class="section-heading">Recent runs</h2>
        @if (!_runs.Any())
        {
            <p class="empty">No runs yet.</p>
        }
        else
        {
            <table class="table">
                <thead>
                    <tr>
                        <th>Trigger</th>
                        <th>Timestamp</th>
                        <th>Result</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var run in _runs)
                    {
                        <tr>
                            <td>@(run.Trigger ?? "—")</td>
                            <td>@run.StartedAt.ToTimeAgo()</td>
                            <td>
                                @{
                                    var (color, text) = run.Status switch
                                    {
                                        "Success" => (PillColor.Success, run.ExitCode is { } c ? $"Success ({c})" : "Success"),
                                        "Failed" => (PillColor.Error, run.ExitCode is { } e ? $"Failed ({e})" : "Failed"),
                                        _ => (PillColor.Muted, run.Status)
                                    };
                                }
                                <Pill Color="@color" Text="@text" />
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
            </section>
        </div>
    </div>

    <Modal Title="Add schedule" Visible="_addScheduleModalVisible" OnClose="CloseAddScheduleModal">
        <div class="form">
            <div class="row">
                <label for="add-schedule-select">Schedule</label>
                <SearchableSelect TItem="Schedule"
                                  Items="_unassignedSchedules"
                                  Value="@_scheduleToAddId"
                                  ValueChanged="OnScheduleToAddChanged"
                                  ValueSelector="s => s.Id"
                                  TextSelector="@(s => s.Name ?? "—")"
                                  Placeholder="Select schedule to add…"
                                  AriaLabel="Select schedule to add" />
            </div>
            <div class="actions">
                <button type="button" disabled="@(_scheduleToAddId is null)" @onclick="AddSchedule">Add</button>
            </div>
        </div>
    </Modal>
}

@code {
    [Parameter]
    public int Id { get; set; }

    private SSAReplacement.Web.Client.JobDetail? _job;
    private List<JobRun> _runs = [];
    private List<Schedule> _allSchedules = [];
    private bool _loading = true;
    private string? _error;
    private string? _triggerMessage;
    private string? _triggerError;
    private bool _triggering;
    private int? _scheduleToAddId;
    private bool _addScheduleModalVisible;

    private IEnumerable<Schedule> _unassignedSchedules =>
        _job is null ? [] : _allSchedules.Where(s => _job.Schedules.All(js => js.Id != s.Id));

    protected override async Task OnParametersSetAsync()
    {
        if (Id > 0)
            await LoadData();
    }

    private async Task LoadData()
    {
        _loading = true;
        _error = null;
        _triggerMessage = null;
        _triggerError = null;
        try
        {
            var jobTask = Api.GetJobAsync(Id);
            var runsTask = Api.GetJobRunsAsync(Id);
            var schedulesTask = Api.GetSchedulesAsync();

            await Task.WhenAll(jobTask, runsTask, schedulesTask);

            _job = await jobTask;
            _runs = await runsTask;
            _allSchedules = await schedulesTask;
        }
        catch (Exception ex)
        {
            _error = "Failed to load: " + ex.Message;
            _job = null;
            _runs = [];
            _allSchedules = [];
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task RunNow()
    {
        if (_job is null) return;
        _triggering = true;
        _triggerMessage = null;
        _triggerError = null;
        try
        {
            await Api.TriggerJobAsync(Id);
            _triggerMessage = "Run queued.";
            await Task.Delay(1500);
            _runs = await Api.GetJobRunsAsync(Id);
        }
        catch (Exception ex)
        {
            _triggerError = ex.Message;
        }
        finally
        {
            _triggering = false;
        }
    }

    private void OnScheduleToAddChanged(int? value)
    {
        _scheduleToAddId = value;
    }

    private void OpenAddScheduleModal() => _addScheduleModalVisible = true;

    private void CloseAddScheduleModal()
    {
        _addScheduleModalVisible = false;
        _scheduleToAddId = null;
    }

    private async Task AddSchedule()
    {
        if (_job is null || _scheduleToAddId is null) return;
        var newIds = _job.Schedules.Select(s => s.Id).Append(_scheduleToAddId.Value).ToArray();
        try
        {
            await Api.SetJobSchedulesAsync(Id, newIds);
            _scheduleToAddId = null;
            _addScheduleModalVisible = false;
            await LoadData();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private async Task RemoveSchedule(int scheduleId)
    {
        if (_job is null) return;
        var newIds = _job.Schedules.Where(s => s.Id != scheduleId).Select(s => s.Id).ToArray();
        try
        {
            await Api.SetJobSchedulesAsync(Id, newIds);
            await LoadData();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }
}

@page "/jobs"
@using SSAReplacement.Web.Shared.Form
@using SSAReplacement.Web.Shared.Pill
@using SSAReplacement.Web.Client
@inject SsaApiClient Api
@inject NavigationManager Nav

<PageTitle>Jobs</PageTitle>

@if (_loading && _jobs.Count == 0)
{
    <div class="status loading">Loading…</div>
}
else if (_error is not null)
{
    <div class="status error">@_error</div>
}

<header class="page-header">
    <h1>Jobs</h1>
    <div class="search-wrap">
        <SearchBar Value="@_searchQuery" ValueChanged="OnSearchChanged" Placeholder="Filter by name…" AriaLabel="Filter jobs by name" />
    </div>
    <div class="page-header-actions">
        <button type="button" @onclick="OpenAddJobModal">Add Job</button>
    </div>
</header>

<Modal Title="Add Job" Visible="_addJob.Visible" OnClose="CloseAddJobModal">
    <div class="form">
        <FormField Label="Name" Required ErrorMessage="@_addJob.NameError" InputId="new-job-name">
            <input id="new-job-name" type="text" value="@_addJob.Name" @oninput="OnAddJobNameChanged" placeholder="Job name" aria-describedby="new-job-name-error" aria-invalid="@(!string.IsNullOrEmpty(_addJob.NameError))" />
        </FormField>
        <FormField Label="Executable" Required ErrorMessage="@_addJob.ExecutableError" InputId="new-job-executable">
            <SearchableSelect 
                TItem="ExecutableItem"
                Items="_executables"
                Value="@_addJob.SelectedExecutableId"
                ValueChanged="OnExecutableSelected"
                ValueSelector="e => e.Id"
                TextSelector="e => e.Name"
                Placeholder="Search executables…"
                AriaLabel="Select executable" />
        </FormField>
        <div class="actions">
            <button type="button" @onclick="SubmitAddJob" disabled="@_addJob.IsSubmitting">Add</button>
            <button type="button" class="btn-secondary" @onclick="CloseAddJobModal">Cancel</button>
        </div>
    </div>
</Modal>

@if (!_filteredJobs.Any())
{
    <p class="empty">@(_jobs.Count == 0 ? "No jobs." : "No jobs match.")</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th class="sortable" @onclick='() => SetSort("name")'>Name <span class="sort-indicator">@SortArrow("name")</span></th>
                <th class="sortable" @onclick='() => SetSort("executableName")'>Executable <span class="sort-indicator">@SortArrow("executableName")</span></th>
                <th class="sortable" @onclick='() => SetSort("isEnabled")'>Enabled <span class="sort-indicator">@SortArrow("isEnabled")</span></th>
                <th>Created</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var job in _sortedJobs)
            {
                <tr class="table-row-clickable" role="button" tabindex="0" @onclick="() => NavigateToJob(job.Id)" @onkeydown="e => HandleRowKey(e, job.Id)">
                    <td>@job.Name</td>
                    <td>@(job.ExecutableName ?? "—")</td>
                    <td><Pill Color="@(job.IsEnabled ? PillColor.Success : PillColor.Muted)" Text="@(job.IsEnabled ? "Enabled" : "Disabled")" /></td>
                    <td>@job.CreatedAt.ToTimeAgo()</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<Job> _jobs = [];
    private List<ExecutableItem> _executables = [];

    private string _searchQuery = "";
    private string _sortColumn = "name";

    private bool _sortAsc = true;

    private bool _loading = true;
    private string? _error;

    private AddJobFormState _addJob = new();

    private IEnumerable<Job> _filteredJobs =>
        string.IsNullOrWhiteSpace(_searchQuery)
            ? _jobs
            : _jobs.Where(j => j.Name.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase));

    private IEnumerable<Job> _sortedJobs =>
        _sortColumn switch
        {
            "name" => _sortAsc ? _filteredJobs.OrderBy(j => j.Name) : _filteredJobs.OrderByDescending(j => j.Name),
            "executableName" => _sortAsc ? _filteredJobs.OrderBy(j => j.ExecutableName) : _filteredJobs.OrderByDescending(j => j.ExecutableName),
            "isEnabled" => _sortAsc ? _filteredJobs.OrderBy(j => j.IsEnabled) : _filteredJobs.OrderByDescending(j => j.IsEnabled),
            _ => _filteredJobs
        };

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        _loading = true;
        _error = null;
        try
        {
            var jobsTask = Api.GetJobsAsync();
            var executablesTask = Api.GetExecutablesAsync();

            await Task.WhenAll(jobsTask, executablesTask);

            _jobs = await jobsTask;
            var execList = await executablesTask;
            _executables = execList.Select(e => new ExecutableItem(e.Id, e.Name)).ToList();
        }
        catch (Exception ex)
        {
            _error = "Failed to load: " + ex.Message;
            _jobs = [];
            _executables = [];
        }
        finally
        {
            _loading = false;
        }
    }

    private void OnSearchChanged(string? value)
    {
        _searchQuery = value ?? "";
    }

    private void NavigateToJob(int jobId)
    {
        Nav.NavigateTo($"/jobs/{jobId}");
    }

    private void HandleRowKey(KeyboardEventArgs e, int jobId)
    {
        if (e.Key == "Enter" || e.Key == " ")
            NavigateToJob(jobId);
    }

    private void SetSort(string column)
    {
        if (_sortColumn == column)
            _sortAsc = !_sortAsc;
        else
        {
            _sortColumn = column;
            _sortAsc = true;
        }
    }

    private string SortArrow(string column)
    {
        if (_sortColumn != column) 
            return "";

        return _sortAsc ? "\u2191" : "\u2193";
    }

    private void OpenAddJobModal()
    {
        _addJob = new AddJobFormState { Visible = true };
    }

    private void CloseAddJobModal()
    {
        _addJob = new AddJobFormState();
    }

    private void OnAddJobNameChanged(ChangeEventArgs e)
    {
        _addJob = _addJob with { Name = e.Value?.ToString() ?? "", NameError = null };
    }

    private void OnExecutableSelected(int? id)
    {
        _addJob = _addJob with { SelectedExecutableId = id, ExecutableError = null };
    }

    private async Task SubmitAddJob()
    {
        _addJob = _addJob with { NameError = null, ExecutableError = null };

        var hasError = false;
        if (string.IsNullOrEmpty(_addJob.Name))
        {
            _addJob = _addJob with { NameError = "Enter a job name." };
            hasError = true;
        }

        if (_addJob.SelectedExecutableId is null || _addJob.SelectedExecutableId.Value < 1)
        {
            _addJob = _addJob with { ExecutableError = "Select an executable." };
            hasError = true;
        }

        if (hasError)
        {
            await InvokeAsync(StateHasChanged);
            return;
        }

        _addJob = _addJob with { IsSubmitting = true };

        try
        {
            var request = new AddJobRequest(
                _addJob.SelectedExecutableId!.Value,
                _addJob.Name.Trim(),
                IsEnabled: true);

            await Api.AddJobAsync(request);

            CloseAddJobModal();
            await LoadData();
        }
        catch (HttpRequestException ex)
        {
            _addJob = _addJob with { ExecutableError = ex.Message };
        }
        catch (Exception ex)
        {
            _addJob = _addJob with { ExecutableError = ex.Message };
        }
        finally
        {
            _addJob = _addJob with { IsSubmitting = false };
        }
    }

    /// <summary>
    /// UI state for the Add Job modal (form values and validation). Not the API request type.
    /// </summary>
    private record AddJobFormState
    {
        public bool Visible { get; init; }
        public string Name { get; init; } = "";
        public int? SelectedExecutableId { get; init; }
        public string? NameError { get; init; }
        public string? ExecutableError { get; init; }
        public bool IsSubmitting { get; init; }
    }
}

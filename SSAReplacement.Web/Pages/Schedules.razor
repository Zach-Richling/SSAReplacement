@page "/schedules"
@using SSAReplacement.Web.Shared.Form
@using SSAReplacement.Web.Shared.Pill
@using SSAReplacement.Web.Client
@inject SsaApiClient Api

<PageTitle>Schedules</PageTitle>

@if (_loading && _schedules.Count == 0)
{
    <div class="status loading">Loading…</div>
}
else if (_error is not null)
{
    <div class="status error">@_error</div>
}

<header class="page-header">
    <h1>Schedules</h1>
    <div class="search-wrap">
        <SearchBar Value="@_searchQuery" ValueChanged="OnSearchChanged" Placeholder="Filter by name…" AriaLabel="Filter schedules by name" />
    </div>
    <div class="page-header-actions">
        <button type="button" @onclick="OpenAddScheduleModal">Add Schedule</button>
    </div>
</header>

<Modal Title="Add Schedule" Visible="_addSchedule.Visible" OnClose="CloseAddScheduleModal">
    <div class="form">
        <FormField Label="Name" ErrorMessage="@_addSchedule.NameError" InputId="new-schedule-name">
            <input id="new-schedule-name" type="text" value="@_addSchedule.Name" @oninput="OnAddScheduleNameChanged" placeholder="Schedule name" aria-describedby="new-schedule-name-error" aria-invalid="@(!string.IsNullOrEmpty(_addSchedule.NameError))" />
        </FormField>
        <FormField Label="Cron expression" Required="true" ErrorMessage="@_addSchedule.CronError" InputId="new-schedule-cron">
            <input id="new-schedule-cron" type="text" value="@_addSchedule.CronExpression" @oninput="OnCronChanged" placeholder="0 * * * *" aria-describedby="new-schedule-cron-error" aria-invalid="@(!string.IsNullOrEmpty(_addSchedule.CronError))" />
        </FormField>
        <div class="actions">
            <button type="button" @onclick="SubmitAddSchedule" disabled="@_addSchedule.IsSubmitting">Add</button>
            <button type="button" class="btn-secondary" @onclick="CloseAddScheduleModal">Cancel</button>
        </div>
    </div>
</Modal>

@if (!_filteredSchedules.Any())
{
    <p class="empty">@(_schedules.Count == 0 ? "No schedules." : "No schedules match.")</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Name</th>
                <th>Cron</th>
                <th>Enabled</th>
                <th>Created</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var schedule in _filteredSchedules)
            {
                <tr>
                    <td>@(schedule.Name ?? "—")</td>
                    <td>
                        @schedule.CronExpression
                        <span class="cron-description-hint" title="@CronDescription.GetDescription(schedule.CronExpression)" aria-label="Schedule description"><i class="bi bi-question-circle"></i></span>
                    </td>
                    <td><Pill Color="@(schedule.IsEnabled ? PillColor.Success : PillColor.Muted)" Text="@(schedule.IsEnabled ? "Enabled" : "Disabled")" /></td>
                    <td>@schedule.CreatedAt.ToTimeAgo()</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<Schedule> _schedules = [];
    private string _searchQuery = "";
    private bool _loading = true;
    private string? _error;

    private AddScheduleFormState _addSchedule = new();

    private IEnumerable<Schedule> _filteredSchedules =>
        string.IsNullOrWhiteSpace(_searchQuery)
            ? _schedules
            : _schedules.Where(s => (s.Name ?? "").Contains(_searchQuery, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        _loading = true;
        _error = null;
        try
        {
            _schedules = await Api.GetSchedulesAsync();
        }
        catch (Exception ex)
        {
            _error = "Failed to load: " + ex.Message;
            _schedules = [];
        }
        finally
        {
            _loading = false;
        }
    }

    private void OnSearchChanged(string? value)
    {
        _searchQuery = value ?? "";
    }

    private void OpenAddScheduleModal()
    {
        _addSchedule = new AddScheduleFormState { Visible = true };
    }

    private void CloseAddScheduleModal()
    {
        _addSchedule = new AddScheduleFormState();
    }

    private void OnAddScheduleNameChanged(ChangeEventArgs e)
    {
        _addSchedule = _addSchedule with { Name = e.Value?.ToString() ?? "", NameError = null };
    }

    private void OnCronChanged(ChangeEventArgs e)
    {
        _addSchedule = _addSchedule with { CronExpression = e.Value?.ToString() ?? "", CronError = null };
    }

    private async Task SubmitAddSchedule()
    {
        _addSchedule = _addSchedule with { NameError = null, CronError = null };

        var cron = (_addSchedule.CronExpression ?? "").Trim();
        var cronError = CronValidation.Validate(cron);
        if (cronError is not null)
        {
            _addSchedule = _addSchedule with { CronError = cronError };
            await InvokeAsync(StateHasChanged);
            return;
        }

        _addSchedule = _addSchedule with { IsSubmitting = true };
        try
        {
            var request = new CreateScheduleRequest(
                string.IsNullOrWhiteSpace(_addSchedule.Name) ? null : _addSchedule.Name.Trim(),
                cron,
                IsEnabled: true);

            await Api.AddScheduleAsync(request);

            CloseAddScheduleModal();
            await LoadData();
        }
        catch (Exception ex)
        {
            _addSchedule = _addSchedule with { CronError = ex.Message };
        }
        finally
        {
            _addSchedule = _addSchedule with { IsSubmitting = false };
        }
    }

    private record AddScheduleFormState
    {
        public bool Visible { get; init; }
        public string Name { get; init; } = "";
        public string CronExpression { get; init; } = "";
        public string? NameError { get; init; }
        public string? CronError { get; init; }
        public bool IsSubmitting { get; init; }
    }
}

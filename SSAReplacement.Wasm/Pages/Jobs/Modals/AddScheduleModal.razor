@using System.ComponentModel.DataAnnotations
@inject SsaApiClient Api
@inject ToastService Toasts

<BbDialog @bind-Open="IsOpen">
    <BbDialogTrigger>
        <BbButton>Add Schedule</BbButton>
    </BbDialogTrigger>
    <BbDialogContent>
        <BbDialogHeader>
            <BbDialogTitle>Add a schedule to the job</BbDialogTitle>
        </BbDialogHeader>
        <EditForm Model="_formState" id="add-job-schedule-form" OnValidSubmit="SubmitAddJobSchedule">
            <DataAnnotationsValidator />
            <BbField Orientation="FieldOrientation.Responsive">
                <BbFieldLabel For="schedule">Schedule</BbFieldLabel>
                <BbCombobox TValue="long" Options="_selectOptions" @bind-Value="_formState.ScheduleId" />
                <ValidationMessage For="() => _formState.ScheduleId" />
            </BbField>
        </EditForm>
        <BbDialogFooter>
            <BbButton Type="ButtonType.Submit" form="add-job-schedule-form" Loading="_submitting">Add</BbButton>
        </BbDialogFooter>
    </BbDialogContent>
</BbDialog>

@code {
    [Parameter]
    public EventCallback OnScheduleCreated { get; set; }

    [Parameter]
    public bool IsOpen { get; set; }

    [Parameter]
    public required JobDetail Job { get; set; }

    private AddJobScheduleFormState _formState = new();
    private List<Schedule> _allSchedules = [];
    private List<SelectOption<long>> _selectOptions => _allSchedules
        .Where(x => !Job.Schedules.Any(y => y.Id == x.Id))
        .Select(s => new SelectOption<long>(s.Id, s.Name))
        .ToList();

    private bool _submitting;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _allSchedules = await Api.Schedule.GetSchedulesAsync();
        } 
        catch (Exception)
        {
            Toasts.Error("Could not load schedule dropdown.");
        }
    }

    private async Task SubmitAddJobSchedule()
    {
        _submitting = true;
        try
        {
            var newSchedules = Job.Schedules.Select(s => s.Id).ToList();
            newSchedules.Add(_formState.ScheduleId);

            await Api.Job.SetJobSchedulesAsync(Job.Id, newSchedules);

            if (OnScheduleCreated.HasDelegate)
            {
                await OnScheduleCreated.InvokeAsync();
            }

            Toasts.Success("Schedule added to job successfully");
            IsOpen = false;
        }
        catch (Exception ex)
        {
            Toasts.Error("Error when adding schedule: " + ex.Message);
        }
        finally
        {
            _submitting = false;
        }
    }

    private class AddJobScheduleFormState
    {
        [Range(1L, long.MaxValue, ErrorMessage = "Please select a schedule.")]
        public long ScheduleId { get; set; }
    }
}

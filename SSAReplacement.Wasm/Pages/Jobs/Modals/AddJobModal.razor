@using System.ComponentModel.DataAnnotations

<BbDialog @bind-Open="IsOpen">
    <BbDialogTrigger>
        <BbButton Size="ButtonSize.Small">
            <Icon>
                <LucideIcon Name="plus" Class="h-4 w-4" />
            </Icon>
            <ChildContent>Add Job</ChildContent>
        </BbButton>
    </BbDialogTrigger>
    <BbDialogContent>
        <BbDialogHeader>
            <BbDialogTitle>Add a job</BbDialogTitle>
        </BbDialogHeader>
        <EditForm Model="_formState" id="add-job-form" OnValidSubmit="SubmitAddJob">
            <DataAnnotationsValidator />
            <BbField>
                <BbFieldLabel For="job-name">Name</BbFieldLabel>
                <BbInputField TValue="string" @bind-Value="_formState.Name" Id="job-name" />
                <ValidationMessage For="() => _formState.Name" />
            </BbField>

            <div class="mt-4">
                <div class="flex items-center justify-between mb-2">
                    <span class="text-sm font-medium">Steps</span>
                    <BbButton Variant="ButtonVariant.Outline" Size="ButtonSize.Small" OnClick="AddStep" Type="ButtonType.Button">
                        <Icon><LucideIcon Name="plus" Class="h-3 w-3" /></Icon>
                        <ChildContent>Add Step</ChildContent>
                    </BbButton>
                </div>

                @if (_formState.Steps.Count == 0)
                {
                    <p class="text-sm text-muted-foreground py-2">No steps defined. Add at least one step.</p>
                }
                else
                {
                    <div class="flex flex-col gap-2">
                        @for (var i = 0; i < _formState.Steps.Count; i++)
                        {
                            var idx = i;
                            <div class="flex items-center gap-2">
                                <span class="text-sm text-muted-foreground w-6 shrink-0">@(idx + 1).</span>
                                <BbInputField TValue="string" @bind-Value="_formState.Steps[idx].Name"
                                              Placeholder="Step name..." Class="w-40 shrink-0" />
                                <BbCombobox TValue="long"
                                            Options="_selectOptions"
                                            @bind-Value="_formState.Steps[idx].SelectedExecutableId"
                                            Placeholder="Select executable..."
                                            MatchTriggerWidth
                                            Class="flex-1" />
                                <BbButton Variant="ButtonVariant.Ghost" Size="ButtonSize.Icon" OnClick="() => RemoveStep(idx)" Type="ButtonType.Button">
                                    <LucideIcon Name="trash-2" Class="h-4 w-4 text-destructive" />
                                </BbButton>
                            </div>
                        }
                    </div>
                }
            </div>
        </EditForm>
        <BbDialogFooter>
            <BbButton Type="ButtonType.Submit" form="add-job-form" Loading="_submitting" Size="ButtonSize.Small">
                <Icon>
                    <LucideIcon Name="plus" Class="h-4 w-4" />
                </Icon>
                <ChildContent>Add</ChildContent>
            </BbButton>
        </BbDialogFooter>
    </BbDialogContent>
</BbDialog>

@code {
    [Inject]
    public required SsaApiClient Api { get; set; }

    [Inject]
    public required ToastService Toasts { get; set; }

    [Parameter]
    public EventCallback OnJobCreated { get; set; }

    public bool IsOpen { get; set; }

    private AddJobFormState _formState = new();

    private List<Executable> _executables = [];
    private List<SelectOption<long>> _selectOptions => _executables.Select(e => new SelectOption<long>(e.Id, e.Name)).ToList();

    private bool _submitting;

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        try
        {
            _executables = await Api.Executable.GetExecutablesAsync();
        }
        catch (Exception)
        {
            _executables = [];
        }
    }

    private void AddStep()
    {
        _formState.Steps.Add(new StepFormState());
    }

    private void RemoveStep(int index)
    {
        _formState.Steps.RemoveAt(index);
    }

    private async Task SubmitAddJob()
    {
        if (_formState.Steps.Count == 0)
        {
            Toasts.Error("At least one step is required.");
            return;
        }

        if (_formState.Steps.Any(s => s.SelectedExecutableId == 0))
        {
            Toasts.Error("Please select an executable for each step.");
            return;
        }

        if (_formState.Steps.Any(s => string.IsNullOrWhiteSpace(s.Name)))
        {
            Toasts.Error("Please enter a name for each step.");
            return;
        }

        _submitting = true;
        try
        {
            var steps = _formState.Steps
                .Select((s, i) => new JobStepRequest(null, s.SelectedExecutableId, i + 1, s.Name))
                .ToList();

            await Api.Job.AddJobAsync(new AddJobRequest(_formState.Name, steps));

            if (OnJobCreated.HasDelegate)
                await OnJobCreated.InvokeAsync();

            Toasts.Success("Job added successfully");
            _formState = new();
            IsOpen = false;
        }
        catch (Exception e)
        {
            Toasts.Error("Failed to add job: " + e.Message);
        }
        finally
        {
            _submitting = false;
        }
    }

    private class StepFormState
    {
        public long SelectedExecutableId { get; set; }
        public string Name { get; set; } = "";
    }

    private class AddJobFormState
    {
        [Required(ErrorMessage = "Please enter a job name")]
        public string Name { get; set; } = "";

        public List<StepFormState> Steps { get; set; } = [];
    }
}

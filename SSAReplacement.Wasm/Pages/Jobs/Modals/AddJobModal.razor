@using System.ComponentModel.DataAnnotations

<BbDialog @bind-Open="IsOpen">
    <BbDialogTrigger>
        <BbButton>Add Job</BbButton>
    </BbDialogTrigger>
    <BbDialogContent>
        <BbDialogHeader>
            <BbDialogTitle>Add a job</BbDialogTitle> 
        </BbDialogHeader>
        @if(!string.IsNullOrEmpty(_error))
        {
            <BbAlert Variant="AlertVariant.Danger">@_error</BbAlert>
        }
        <EditForm Model="_formState" id="add-job-form" OnValidSubmit="SubmitAddJob">
            <DataAnnotationsValidator />
            <BbField>
                <BbFieldLabel For="job-name">Name</BbFieldLabel>
                <BbInputField TValue="string" @bind-Value="_formState.Name" Id="job-name" />
                <ValidationMessage For="() => _formState.Name" />
            </BbField>
            <BbField Class="mt-4" Orientation="FieldOrientation.Responsive">
                <BbFieldLabel For="executable-id">Executable</BbFieldLabel>
                <BbCombobox TValue="int" Options="_selectOptions" @bind-Value="_formState.SelectedExecutableId" />
                <ValidationMessage For="() => _formState.SelectedExecutableId" />
            </BbField>
        </EditForm>
        <BbDialogFooter>
            <BbButton Type="ButtonType.Submit" form="add-job-form">Add</BbButton>
        </BbDialogFooter>
    </BbDialogContent>
</BbDialog>

@code {
    [Inject]
    public required SsaApiClient Api { get; set; }

    [Parameter]
    public EventCallback OnJobCreated { get; set; }

    public bool IsOpen { get; set; }

    private AddJobFormState _formState = new();

    private List<Executable> _executables = [];
    private List<SelectOption<int>> _selectOptions => _executables.Select(e => new SelectOption<int>(e.Id, e.Name)).ToList();

    private string? _error;

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        try
        {
            _executables = await Api.Executable.GetExecutablesAsync();
        }
        catch (Exception ex)
        {
            _error = "Failed to executables: " + ex.Message;
            _executables = [];
        }
    }

    private async Task SubmitAddJob()
    {
        try
        {
            await Api.Job.AddJobAsync(new AddJobRequest(
                _formState.SelectedExecutableId,
                _formState.Name));

            if (OnJobCreated.HasDelegate)
            {
                await OnJobCreated.InvokeAsync();
            }

            IsOpen = false;
        } 
        catch (Exception e)
        {
            _error = "Failed to add job: " + e.Message;
        }
    }

    private class AddJobFormState
    {
        [Required(ErrorMessage = "Please enter a job name")]
        public string Name { get; set; } = "";

        [Range(1, double.MaxValue, ErrorMessage = "Please select an executable.")]
        public int SelectedExecutableId { get; set; }
    }
}
@using SSAReplacement.Wasm.Pages.Jobs.Modals
@using SSAReplacement.Wasm.Pages.Jobs.Models
@using SSAReplacement.Wasm.Client.Executables
@using SSAReplacement.Wasm.Client.Jobs

@inject SsaApiClient Api
@inject ToastService Toasts

<BbAccordionItem Value="job-steps">
    <BbAccordionTrigger>Steps</BbAccordionTrigger>
    <BbAccordionContent>
        @if (_editingSteps)
        {
            <BbSortable TItem="StepEditState"
                        Items="_editSteps"
                        Handle=".drag-handle"
                        OnUpdate="OnStepReordered"
                        Class="mb-3">
                <ItemTemplate Context="step">
                    <div class="flex items-center gap-3 rounded-md border bg-card px-3 py-2">
                        <LucideIcon Name="grip-vertical" Class="drag-handle h-4 w-4 shrink-0 cursor-grab text-muted-foreground" />
                        <span class="text-sm text-muted-foreground w-6 shrink-0">@(_editSteps.IndexOf(step) + 1).</span>
                        <BbInputField TValue="string" @bind-Value="step.Name"
                                      Placeholder="Step name..." Class="w-40 shrink-0" />
                        <BbCombobox TValue="long"
                                    Options="_executableSelectOptions"
                                    @bind-Value="step.SelectedExecutableId"
                                    Placeholder="Select executable..." />
                        <BbButton Variant="ButtonVariant.Ghost" Size="ButtonSize.Icon" Class="ml-auto"
                                  OnClick="() => RemoveEditStep(_editSteps.IndexOf(step))">
                            <LucideIcon Name="trash-2" Class="h-4 w-4 text-destructive" />
                        </BbButton>
                    </div>
                </ItemTemplate>
            </BbSortable>
            <div class="flex gap-2">
                <BbButton Variant="ButtonVariant.Outline" Size="ButtonSize.Small" OnClick="AddEditStep">
                    <Icon><LucideIcon Name="plus" Class="h-3 w-3" /></Icon>
                    <ChildContent>Add Step</ChildContent>
                </BbButton>
                <div class="flex gap-2 ml-auto">
                    <BbButton Size="ButtonSize.Small" OnClick="SaveSteps" Loading="_savingSteps">
                        <Icon><LucideIcon Name="save" Class="h-4 w-4" /></Icon>
                        <ChildContent>Save</ChildContent>
                    </BbButton>
                    <BbButton Variant="ButtonVariant.Ghost" Size="ButtonSize.Small" OnClick="CancelEditSteps">Cancel</BbButton>
                </div>
            </div>
        }
        else
        {
            <BbDataGrid TData="JobStep"
                        Items="@(Job.Steps.OrderBy(s => s.StepNumber))"
                        ItemKey="@(s => s.Id)"
                        ShowPagination="false"
                        Class="steps-grid rounded-lg overflow-hidden">
                <Columns>
                    <BbDataGridExpandColumn />
                    <BbDataGridPropertyColumn Property="@(s => s.StepNumber)" Title="#" Width="60px" />
                    <BbDataGridPropertyColumn Property="@(s => s.Name)" Title="Step Name" />
                    <BbDataGridPropertyColumn Property="@(s => s.ExecutableName)" Title="Executable" />
                    <BbDataGridTemplateColumn Title="Parameters" Width="130px">
                        <ChildContent Context="step">
                            @{ var paramItems = StepParameterItems.TryGetValue(step.Id, out var pi) ? pi : []; }
                            <span>@paramItems.Count parameter@(paramItems.Count == 1 ? "" : "s")</span>
                        </ChildContent>
                    </BbDataGridTemplateColumn>
                    <BbDataGridTemplateColumn Title="" Width="48px">
                        <ChildContent Context="step">
                            @{ var warnItems = StepParameterItems.TryGetValue(step.Id, out var wi) ? wi : []; }
                            @if (warnItems.Any(x => x.IsRequired && string.IsNullOrEmpty(x.Value)))
                            {
                                <BbTooltip>
                                    <BbTooltipTrigger>
                                        <LucideIcon Name="triangle-alert" Class="h-4 w-4 text-yellow-400" />
                                    </BbTooltipTrigger>
                                    <BbTooltipContent>One or more required parameters are not set</BbTooltipContent>
                                </BbTooltip>
                            }
                        </ChildContent>
                    </BbDataGridTemplateColumn>
                </Columns>
                <DetailTemplate Context="step">
                    @{ var stepItems = StepParameterItems.TryGetValue(step.Id, out var di) ? di : []; }
                    <div class="p-3">
                        @if (stepItems.Count == 0)
                        {
                            <p class="text-sm text-muted-foreground py-1">No parameters defined for this executable.</p>
                        }
                        else
                        {
                            <BbDataTable Data="stepItems" TData="JobParameterDisplayItem" ShowToolbar="false" ShowPagination="false">
                                <Columns>
                                    <BbDataTableColumn TData="JobParameterDisplayItem" TValue="string" Property="x => x.Key" Header="Name" />
                                    <BbDataTableColumn TData="JobParameterDisplayItem" TValue="string" Property="@(x => x.Description ?? "-")" Header="Description" />
                                    <BbDataTableColumn TData="JobParameterDisplayItem" TValue="string" Property="x => x.Type" Header="Type" />
                                    <BbDataTableColumn TData="JobParameterDisplayItem" TValue="string" Property="@(x => x.Value ?? "-")" Header="Value" />
                                    <BbDataTableColumn TData="JobParameterDisplayItem" TValue="bool" Property="x => x.IsRequired" Header="Required?" />
                                    <BbDataTableColumn TData="JobParameterDisplayItem" TValue="string" Header="Actions">
                                        <CellTemplate>
                                            <EditJobParameterModal Item="context" OnParameterEdited="StateHasChanged" />
                                        </CellTemplate>
                                    </BbDataTableColumn>
                                    <BbDataTableColumn TData="JobParameterDisplayItem" TValue="bool" Header="">
                                        <CellTemplate>
                                            @if (!context.IsExecutableParameter)
                                            {
                                                <LucideIcon Name="triangle-alert" Class="h-4 w-4" Color="#FFFF00" />
                                            }
                                        </CellTemplate>
                                    </BbDataTableColumn>
                                </Columns>
                            </BbDataTable>
                        }
                    </div>
                </DetailTemplate>
            </BbDataGrid>
            <BbButton Variant="ButtonVariant.Outline" Size="ButtonSize.Small" Class="mt-3" OnClick="StartEditSteps">
                <Icon><LucideIcon Name="pencil" Class="h-4 w-4" /></Icon>
                <ChildContent>Edit Steps</ChildContent>
            </BbButton>
        }
    </BbAccordionContent>
</BbAccordionItem>

@if (UnsavedChangeCount > 0)
{
    <div class="unsaved-changes-bar">
        <LucideIcon Name="save" Class="h-4 w-4 shrink-0" />
        <span>You have <strong>@UnsavedChangeCount</strong> unsaved changes</span>
        <BbButton Size="ButtonSize.Small" OnClick="SaveAllStepParameters" Loading="_savingParameters">
            <Icon>
                <LucideIcon Name="save" Class="h-4 w-4" />
            </Icon>
            <ChildContent>
                @(_savingParameters ? "Saving…" : "Save Changes")
            </ChildContent>
        </BbButton>
    </div>
}

@code {
    [Parameter, EditorRequired]
    public SSAReplacement.Wasm.Client.Jobs.JobDetail Job { get; set; } = null!;

    [Parameter, EditorRequired]
    public Dictionary<long, List<JobParameterDisplayItem>> StepParameterItems { get; set; } = new();

    [Parameter, EditorRequired]
    public List<Executable> Executables { get; set; } = [];

    [Parameter]
    public EventCallback OnStepsChanged { get; set; }

    private List<SelectOption<long>> _executableSelectOptions =>
        Executables.Select(e => new SelectOption<long>(e.Id, e.Name)).ToList();

    // Original values snapshot for unsaved-changes tracking: stepId -> (key -> value)
    private Dictionary<long, Dictionary<string, string?>> _originalStepParameterValues = new();
    private Dictionary<long, List<JobParameterDisplayItem>>? _lastStepParameterItems;

    private bool _savingParameters;
    private bool _editingSteps;
    private List<StepEditState> _editSteps = [];
    private bool _savingSteps;

    private int UnsavedChangeCount => StepParameterItems.Sum(kvp =>
    {
        if (!_originalStepParameterValues.TryGetValue(kvp.Key, out var originals))
            return 0;
        return kvp.Value.Count(item => originals.TryGetValue(item.Key, out var orig) && item.Value != orig);
    });

    protected override void OnParametersSet()
    {
        if (!ReferenceEquals(StepParameterItems, _lastStepParameterItems))
        {
            _lastStepParameterItems = StepParameterItems;
            _originalStepParameterValues = StepParameterItems.ToDictionary(
                kvp => kvp.Key,
                kvp => kvp.Value.ToDictionary(x => x.Key, x => x.Value)
            );
        }
    }

    private void StartEditSteps()
    {
        _editSteps = Job.Steps.OrderBy(s => s.StepNumber)
            .Select(s => new StepEditState { JobStepId = s.Id, SelectedExecutableId = s.ExecutableId, Name = s.Name })
            .ToList();
        _editingSteps = true;
    }

    private void CancelEditSteps()
    {
        _editingSteps = false;
        _editSteps = [];
    }

    private void AddEditStep() => _editSteps.Add(new StepEditState());

    private void RemoveEditStep(int index) => _editSteps.RemoveAt(index);

    private void OnStepReordered((int OldIndex, int NewIndex) e)
    {
        var item = _editSteps[e.OldIndex];
        _editSteps.RemoveAt(e.OldIndex);
        _editSteps.Insert(e.NewIndex, item);
    }

    private async Task SaveSteps()
    {
        if (_editSteps.Count == 0)
        {
            Toasts.Error("At least one step is required.");
            return;
        }

        if (_editSteps.Any(s => s.SelectedExecutableId == 0))
        {
            Toasts.Error("Please select an executable for each step.");
            return;
        }

        if (_editSteps.Any(s => string.IsNullOrWhiteSpace(s.Name)))
        {
            Toasts.Error("Please enter a name for each step.");
            return;
        }

        _savingSteps = true;
        try
        {
            var steps = _editSteps
                .Select((s, i) => new JobStepRequest(s.JobStepId, s.SelectedExecutableId, i + 1, s.Name))
                .ToList();

            await Api.Job.SetJobStepsAsync(Job.Id, steps);
            await OnStepsChanged.InvokeAsync();
            _editingSteps = false;
            Toasts.Success("Steps saved successfully");
        }
        catch (Exception)
        {
            Toasts.Error("An error occurred while saving steps");
        }
        finally
        {
            _savingSteps = false;
        }
    }

    private async Task SaveAllStepParameters()
    {
        _savingParameters = true;
        try
        {
            foreach (var (stepId, items) in StepParameterItems)
            {
                if (!_originalStepParameterValues.TryGetValue(stepId, out var originals))
                    continue;

                var hasChanges = items.Any(item => originals.TryGetValue(item.Key, out var orig) && item.Value != orig);
                if (!hasChanges)
                    continue;

                Dictionary<string, string?> parameters = items
                    .Where(x => x.Value is not null)
                    .ToDictionary(x => x.Key, x => x.Value);

                await Api.Job.SetJobStepParametersAsync(Job.Id, stepId, parameters);
            }

            await OnStepsChanged.InvokeAsync();
            Toasts.Success("Job parameters were saved successfully");
        }
        catch (HttpRequestException)
        {
            Toasts.Error("An error occurred while saving job parameters");
        }
        finally
        {
            _savingParameters = false;
        }
    }

    private class StepEditState
    {
        public long? JobStepId { get; set; }
        public long SelectedExecutableId { get; set; }
        public string Name { get; set; } = "";
    }
}

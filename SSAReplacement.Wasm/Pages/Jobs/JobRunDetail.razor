@page "/jobs/{JobId:long}/runs/{Id:long}"
@using Humanizer
@implements IAsyncDisposable

@inject SsaApiClient Api
@inject BreadcrumbService Breadcrumbs
@inject ToastService Toasts
@inject IJSRuntime JSRuntime

<PageTitle>Job Run Detail</PageTitle>

@if (_loading)
{
    <BbAlert Variant="AlertVariant.Info" Class="mt-4">Loading…</BbAlert>
}
else if (_hasError)
{
    <BbAlert Variant="AlertVariant.Danger" Class="mt-4">@_error</BbAlert>
}
else
{
    <div class="grid grid-cols-2 gap-3 mt-3">
        <BbCard>
            <BbCardHeader Class="flex flex-row justify-between items-center">
                Run Overview
                @if (JobRun.Status == "Running")
                {
                    <BbButton Variant="ButtonVariant.Destructive"
                              OnClick="StopRunAsync"
                              Size="ButtonSize.Small"
                              Loading="_stopping">
                        <Icon>
                            <LucideIcon Name="square" Class="h-4 w-4" />
                        </Icon>
                        <ChildContent>Stop Job</ChildContent>
                    </BbButton>
                }
            </BbCardHeader>
            <BbCardContent>
                <div class="grid grid-cols-2 gap-1">
                    <div class="font-medium">Status</div>
                    <div>
                        <BbBadge Variant="@(JobRun.Status switch
                        {
                            "Failed" or "Stopped" => BadgeVariant.Destructive,
                            "Running" => BadgeVariant.Secondary,
                            _ => BadgeVariant.Default
                        })">@JobRun.Status</BbBadge>
                    </div>

                    <div class="font-medium">Trigger</div>
                    <div>@(JobRun.Trigger ?? "-")</div>

                    <div class="font-medium">Started</div>
                    <div>@JobRun.StartedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</div>

                    <div class="font-medium">Duration</div>
                    <div>
                        @if (JobRun.FinishedAt.HasValue)
                        {
                            @((JobRun.FinishedAt.Value - JobRun.StartedAt).Humanize())
                        }
                        else
                        {
                            <span>-</span>
                        }
                    </div>

                    @if (JobRun.Status == "Running" && JobRun.CurrentStep.HasValue)
                    {
                        <div class="font-medium">Current Step</div>
                        <div>Step @JobRun.CurrentStep</div>
                    }
                </div>
            </BbCardContent>
        </BbCard>

        <BbCard>
            <BbCardHeader>Steps</BbCardHeader>
            <BbCardContent>
                @if (JobRun.RunSteps.Count == 0)
                {
                    <p class="text-sm text-muted-foreground">No steps recorded yet.</p>
                }
                else
                {
                    <BbDataTable Data="JobRun.RunSteps.OrderBy(s => s.StepNumber).ToList()" TData="JobRunStep" ShowToolbar="false" ShowPagination="false">
                        <Columns>
                            <BbDataTableColumn TData="JobRunStep" TValue="int" Property="x => x.StepNumber" Header="#" />
                            <BbDataTableColumn TData="JobRunStep" TValue="string" Property="x => x.StepName" Header="Name" />
                            <BbDataTableColumn TData="JobRunStep" TValue="string" Header="Status">
                                <CellTemplate Context="step">
                                    <BbBadge Variant="@(step.Status switch
                                    {
                                        "Failed" or "Stopped" => BadgeVariant.Destructive,
                                        "Running" => BadgeVariant.Secondary,
                                        _ => BadgeVariant.Default
                                    })">@step.Status</BbBadge>
                                </CellTemplate>
                            </BbDataTableColumn>
                            <BbDataTableColumn TData="JobRunStep" TValue="string" Header="Duration">
                                <CellTemplate Context="step">
                                    @if (step.FinishedAt.HasValue)
                                    {
                                        @((step.FinishedAt.Value - step.StartedAt).Humanize())
                                    }
                                    else
                                    {
                                        <span>-</span>
                                    }
                                </CellTemplate>
                            </BbDataTableColumn>
                            <BbDataTableColumn TData="JobRunStep" TValue="int?" Property="x => x.ExitCode" Header="Exit Code">
                                <CellTemplate Context="step">
                                    @(step.ExitCode.HasValue ? step.ExitCode.Value.ToString() : "-")
                                </CellTemplate>
                            </BbDataTableColumn>
                        </Columns>
                    </BbDataTable>
                }
            </BbCardContent>
        </BbCard>
    </div>

    <BbCard Class="mt-3">
        <BbCardHeader>
            <div class="flex flex-row justify-between items-center w-full">
                <div>
                    <BbCardTitle>Job Logs</BbCardTitle>
                    <BbCardDescription>Logs are streamed - @(_consumerRef?.ConnectionState ?? EventSourceState.Disconnected)</BbCardDescription>
                </div>
                @if (JobRun.RunSteps.Count > 0)
                {
                    <BbSelect TValue="long?" @bind-Value="_selectedStepId" Class="w-[180px]">
                        <BbSelectTrigger TValue="long?">
                            <BbSelectValue Placeholder="All Steps" />
                        </BbSelectTrigger>
                        <BbSelectContent TValue="long?">
                            <BbSelectItem TValue="long?" Value="null" Text="All Steps">All Steps</BbSelectItem>
                            @foreach (var step in JobRun.RunSteps.OrderBy(s => s.StepNumber))
                            {
                                <BbSelectItem TValue="long?" Value="step.Id" Text="@($"Step {step.StepNumber} - {step.StepName}")" />
                            }
                        </BbSelectContent>
                    </BbSelect>
                }
            </div>
            <BbSeparator />
        </BbCardHeader>
        <BbCardContent>
            <BbScrollArea MaxHeight="400px">
                <BbEventConsumer Url="@Api.Job.GetJobLogStreamUrl(Id)" OnConnectionStateChanged="StateHasChanged" @ref="_consumerRef">
                    <BbEventTemplate Event="job-log" TValue="JobLog" RenderMode="EventRenderMode.Accumulate" OnRender="() => _scrollToBottom = true" Predicate="LogStepFilter">
                        @{
                            var logLevel = LogLevelFromLogType(context.LogType);
                            var logDateStr = context.LogDate.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss.fff");
                        }
                        <div class="whitespace-pre-wrap break-all">
                            <span>[ @logDateStr</span><span class="@(logLevel == "ERROR" ? "text-destructive" : "text-primary")">@(" " + logLevel)</span><span>] @context.Content</span>
                        </div>
                    </BbEventTemplate>
                </BbEventConsumer>
                <div id="log-list-end"></div>
            </BbScrollArea>
        </BbCardContent>
    </BbCard>
}

@code {
    [Parameter]
    public long JobId { get; set; }

    [Parameter]
    public long Id { get; set; }

    public JobRun JobRun { get; set; } = null!;

    private string? _error;
    private bool _loading = true;
    private bool _hasError => !string.IsNullOrEmpty(_error);
    private bool _scrollToBottom;
    private bool _stopping;
    private long? _selectedStepId;

    private BbEventConsumer? _consumerRef;
    private CancellationTokenSource? _pollCts;

    private static string LogLevelFromLogType(string logType) => logType == "StdOut" ? "INFO" : "ERROR";

    private bool LogStepFilter(JobLog log) => _selectedStepId is null || log.JobRunStepId == _selectedStepId;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var jobRun = await Api.Job.GetJobRunAsync(Id);
            if (jobRun is null)
            {
                _error = "Job run not found.";
                _loading = false;
                return;
            }

            JobRun = jobRun;

            if (JobRun.Status == "Running")
                StartPolling();
        }
        catch (Exception e)
        {
            _error = $"Error loading job run: {e.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    protected override void OnParametersSet()
    {
        Breadcrumbs.Set(
           new BreadcrumbItem() { Text = "Jobs", Url = "/jobs" },
           new BreadcrumbItem() { Text = "Job Detail", Url = $"/jobs/{JobId}" },
           new BreadcrumbItem() { Text = "Job Run Detail" }
       );
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender && _scrollToBottom)
        {
            _scrollToBottom = false;

            try
            {
                await JSRuntime.InvokeVoidAsync("scrollIntoViewById", "log-list-end");
            }
            catch (JSDisconnectedException) { }
        }
    }

    private async Task StopRunAsync()
    {
        _stopping = true;
        try
        {
            var result = await Api.Job.StopJobRunAsync(Id);
            if (result.Success)
            {
                Toasts.Success("Job run stopped successfully");

                var updated = await Api.Job.GetJobRunAsync(Id);
                if (updated is null)
                    return;

                JobRun = updated;
            }
            else
                Toasts.Error(result.Message ?? "Job run could not be stopped.");
        }
        catch (Exception)
        {
            Toasts.Error("Failed to stop job run");
        }
        finally
        {
            _stopping = false;
        }
    }

    private void StartPolling()
    {
        _pollCts = new CancellationTokenSource();
        _ = PollRunStatusAsync(_pollCts.Token);
    }

    private async Task PollRunStatusAsync(CancellationToken cancellationToken)
    {
        while (!cancellationToken.IsCancellationRequested)
        {
            try
            {
                await Task.Delay(3000, cancellationToken);

                var updated = await Api.Job.GetJobRunAsync(Id);
                if (updated is null) break;

                JobRun = updated;
                await InvokeAsync(StateHasChanged);

                if (updated.Status != "Running")
                    break;
            }
            catch (OperationCanceledException)
            {
                break;
            }
            catch (Exception) { }
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_pollCts is CancellationTokenSource cts)
        {
            await cts.CancelAsync();
            cts.Dispose();
        }
    }
}

@page "/jobs"

@using SSAReplacement.Wasm.Pages.Jobs.Modals
@using BlazorBlueprint.Primitives.Filtering

@inject SsaApiClient Api
@inject NavigationManager Nav
@inject BreadcrumbService Breadcrumbs
@inject ToastService Toasts
@inject DialogService Dialogs

<PageTitle>Jobs</PageTitle>

@if (_error is not null)
{
    <BbAlert Variant="AlertVariant.Danger" Class="mt-4">@_error</BbAlert>
}

<div class="flex w-full items-center gap-3">
    <div class="flex-1 min-w-0 flex justify-start">
        Jobs
    </div>
    <div class="flex flex-wrap items-center justify-center gap-3 shrink-0">
        <div class="flex items-center w-full max-w-md min-w-[12rem] gap-3">
            <SearchBar @bind-Value="_searchQuery" AriaLabel="Search jobs by name" />
            <BbPopover>
                <BbPopoverTrigger>
                    <BbButton Variant="ButtonVariant.Outline" Size="ButtonSize.Small" Class="@(_jobFilter.IsEmpty ? null : "border-primary/60")">
                        <LucideIcon Name="list-filter-plus" Class="h-4 w-4" />
                        @if (!_jobFilter.IsEmpty)
                        {
                            <BbBadge Variant="BadgeVariant.Default" Class="ml-2 py-0 px-1.5 text-[10px]">@_jobFilter.TotalConditionCount</BbBadge>
                        }
                    </BbButton>
                </BbPopoverTrigger>
                <BbPopoverContent Class="w-[100vw-2rem] overflow-y-auto">
                    <BbFilterBuilder @bind-Filter="_jobFilter" Fields="_jobFilterFields" Compact OnFilterChanged="() => _gridState.Selection.Clear()" />
                </BbPopoverContent>
            </BbPopover>
        </div>
    </div>
    <div class="flex-1 min-w-0 flex justify-end items-center gap-3">
        <BbSplitButton Size="ButtonSize.Small" Variant="ButtonVariant.Outline" Disabled="@(_gridState.TotalSelected == 0)">
            <ChildContent>
                <span class="text-sm">@(_gridState.TotalSelected > 0 ? $"{_gridState.TotalSelected} selected" : "No rows selected")</span>
            </ChildContent>
            <DropdownContent>
                <BbSplitButtonItem Disabled="@(_gridState.TotalSelected == 0 || _bulkToggleBusy)" OnClick="() => ToggleSelectedEnabledAsync(true)">
                    <LucideIcon Name="power" Class="mr-2 h-4 w-4" />
                    Enable Selected
                </BbSplitButtonItem>
                <BbSplitButtonSeparator />
                <BbSplitButtonItem Class="text-secondary" Disabled="@(_gridState.TotalSelected == 0 || _bulkToggleBusy)" OnClick="() => ToggleSelectedEnabledAsync(false)">
                    <LucideIcon Name="power-off" Class="mr-2 h-4 w-4" />
                    Disable Selected
                </BbSplitButtonItem>
                <BbSplitButtonSeparator />
                <BbSplitButtonItem Class="text-destructive" Disabled="@(_gridState.TotalSelected == 0 || _deleting)" OnClick="DeleteSelectedAsync">
                    <LucideIcon Name="trash" Class="mr-2 h-4 w-4" />
                    Delete Selected
                </BbSplitButtonItem>
            </DropdownContent>
        </BbSplitButton>
        <AddJobModal OnJobCreated="LoadData" />
    </div>
</div>

<BbDataGrid TData="Job"
            Items="@_displayJobs"
            @bind-State="_gridState"
            ItemKey="@(j => j.Id)"
            IsLoading="@_loading"
            Resizable
            StickyHeader
            SelectionMode="DataTableSelectionMode.Multiple">
    <Columns>
        <BbDataGridSelectColumn TData="Job" Pinned="BlazorBlueprint.Primitives.DataGrid.ColumnPinning.Left" />
        <BbDataGridPropertyColumn TData="Job" TProp="string" Property="@(x => x.Name)" Title="Job Name" Sortable />
        <BbDataGridTemplateColumn TData="Job" Title="Enabled" Sortable SortBy="@(x => x.IsEnabled)">
            <BbBadge Variant="@(context.IsEnabled ? BadgeVariant.Default : BadgeVariant.Secondary)">@(context.IsEnabled ? "Enabled" : "Disabled")</BbBadge>
        </BbDataGridTemplateColumn>
        <BbDataGridTemplateColumn TData="Job" Title="Next run" Sortable SortBy="@(x => x.NextRunUtc)">
            @(context.NextRunLocal is DateTime dt ? dt.ToString("g") : "-")
        </BbDataGridTemplateColumn>
        <BbDataGridTemplateColumn TData="Job" Title="Created" Sortable SortBy="@(x => x.CreatedAt)">
            @context.CreatedAt.ToTimeAgo()
        </BbDataGridTemplateColumn>
        <BbDataGridTemplateColumn TData="Job" Title="Actions">
            <BbButton Variant="ButtonVariant.Outline" Size="ButtonSize.Small" OnClick="() => NavigateToJob(context.Id)">
                <Icon>
                    <LucideIcon Name="eye" Class="h-4 w-4" />
                </Icon>
                <ChildContent>View</ChildContent>
            </BbButton>
        </BbDataGridTemplateColumn>
    </Columns>
    <EmptyTemplate>
        <div class="flex flex-row justify-center rounded-md border mt-4">
            <span class="p-4 text-center text-muted">No jobs found.</span>
        </div>
    </EmptyTemplate>
</BbDataGrid>

@code {
    private BlazorBlueprint.Primitives.DataGrid.DataGridState<Job> _gridState = new();

    private List<Job> _jobs = [];

    private string _searchQuery = "";
    private FilterDefinition _jobFilter = new();

    private readonly FilterField[] _jobFilterFields =
    [
        new FilterField { Name = nameof(Job.NextRunLocal), Label = "Next Run", Type = FilterFieldType.DateTime },
        new FilterField { Name = nameof(Job.IsEnabled), Label = "Enabled", Type = FilterFieldType.Boolean }
    ];

    private bool _loading = true;
    private string? _error;

    private bool _deleting;
    private bool _bulkToggleBusy;

    private IEnumerable<Job> _displayJobs
    {
        get
        {
            IEnumerable<Job> q = _jobs;

            if (!string.IsNullOrWhiteSpace(_searchQuery))
                q = q.Where(j => j.Name.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase));

            if (!_jobFilter.IsEmpty)
            {
                var predicate = _jobFilter.ToFunc<Job>(_jobFilterFields);
                q = q.Where(predicate);
            }

            return q;
        }
    }

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        _loading = true;
        _error = null;

        try
        {
            _jobs = await Api.Job.GetJobsAsync();
        }
        catch (Exception ex)
        {
            _error = "Failed to load: " + ex.Message;
            _jobs = [];
        }
        finally
        {
            _loading = false;
        }
    }

    private void NavigateToJob(long jobId) => Nav.NavigateTo($"/jobs/{jobId}");

    private async Task ToggleSelectedEnabledAsync(bool toggleDirection)
    {
        var selected = _gridState.Selection.SelectedItems.ToList();
        var toToggle = selected.Where(j => j.IsEnabled != toggleDirection).ToList();

        if (toToggle.Count == 0)
        {
            var toggleText = toggleDirection ? "enabled" : "disabled";
            Toasts.Success(selected.Count == 0 ? "Select at least one job." : $"Selected jobs are already {toggleText}.");
            return;
        }

        _bulkToggleBusy = true;

        try
        {
            foreach (var job in toToggle)
                await Api.Job.UpdateJobAsync(job.Id, new UpdateJobRequest(job.Name, toggleDirection, job.NotifyEmail));

            var toggleText = toggleDirection ? "Enabled" : "Disabled";
            Toasts.Success($"{toggleText} {toToggle.Count} job(s).");

            await LoadData();

            _gridState.Selection.Clear();
        }
        catch (Exception ex)
        {
            var toggleText = toggleDirection ? "enable" : "disable";
            Toasts.Error($"Failed to {toggleText} jobs: {ex.Message}");
        }
        finally
        {
            _bulkToggleBusy = false;
        }
    }

    private async Task DeleteSelectedAsync()
    {
        if (_gridState.TotalSelected == 0)
            return;

        var selected = _gridState.Selection.SelectedItems;

        var confirm = await Dialogs.ConfirmAsync(
            "Delete jobs?",
            $"Delete {selected.Count} job(s)? This cannot be undone.",
            new ConfirmDialogOptions { Destructive = true });

        if (!confirm.Confirmed)
            return;

        _deleting = true;
        try
        {
            var deleted = 0;
            foreach (var job in selected)
            {
                await Api.Job.DeleteJobAsync(job.Id);
                deleted++;
            }

            Toasts.Success($"Deleted {deleted} job(s).");
            await LoadData();

            _gridState.Selection.Clear();
        }
        catch (Exception ex)
        {
            Toasts.Error("Failed to delete jobs: " + ex.Message);
        }
        finally
        {
            _deleting = false;
        }
    }

    protected override void OnParametersSet()
    {
        Breadcrumbs.Set(new BreadcrumbItem() { Text = "Jobs" });
    }
}

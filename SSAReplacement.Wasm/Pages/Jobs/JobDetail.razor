@page "/jobs/{Id:long}"
@using Humanizer
@using SSAReplacement.Wasm.Pages.Jobs.Modals
@using SSAReplacement.Wasm.Pages.Jobs.Models

@inject SsaApiClient Api
@inject NavigationManager Nav
@inject BreadcrumbService Breadcrumbs
@inject ToastService Toasts

<PageTitle>Job Detail</PageTitle>

@if (_loading)
{
    <BbAlert Variant="AlertVariant.Info" Class="mt-4">Loading…</BbAlert>
}
else if (_hasError)
{
    <BbAlert Variant="AlertVariant.Danger" Class="mt-4">@_error</BbAlert>
}
else
{
    <div class="grid grid-cols-2 gap-3 mt-3">
        <BbCard>
            <BbCardHeader Class="flex flex-row justify-between items-center">
                Job Details
                <div>
                    <BbButton Size="ButtonSize.Small" OnClick="TriggerJobRun" Loading="_triggeringJob">
                        <Icon>
                            <LucideIcon Name="play" Class="h-4 w-4" />
                        </Icon>
                        <ChildContent>Start</ChildContent>
                    </BbButton>
                    <BbButton Size="ButtonSize.Small" OnClick="ToggleEnabled" Class="ml-2" Loading="_togglingEnabled" Variant="@(_job.IsEnabled ? ButtonVariant.Secondary : ButtonVariant.Default)">
                        <Icon>
                            @if (_job.IsEnabled)
                            {
                                <LucideIcon Name="power-off" Class="h-4 w-4" />
                            }
                            else
                            {
                                <LucideIcon Name="power" Class="h-4 w-4" />
                            }
                        </Icon>
                        <ChildContent>
                            @(_job.IsEnabled ? "Disable" : "Enable")
                        </ChildContent>
                    </BbButton>
                </div>
            </BbCardHeader>
            <BbCardContent>
                <div class="grid grid-cols-2 gap-1">
                    <div class="font-medium">Name</div>
                    <div>@_job.Name</div>

                    <div class="font-medium">Steps</div>
                    <div>@_job.Steps.Count step@(_job.Steps.Count == 1 ? "" : "s")</div>

                    <div class="font-medium">Created At</div>
                    <div>@_job.CreatedAt.ToTimeAgo()</div>

                    <div class="font-medium">Enabled</div>
                    <div><BbBadge Variant="@(_job.IsEnabled? BadgeVariant.Default: BadgeVariant.Secondary)">@(_job.IsEnabled ? "Enabled" : "Disabled")</BbBadge></div>
                </div>
            </BbCardContent>
        </BbCard>
        <BbCard>
            <BbCardHeader Class="flex flex-row justify-between items-center">
                Schedules
                <AddScheduleModal Job="_job" OnScheduleCreated="LoadJob" />
            </BbCardHeader>
            <BbCardContent>
                <BbDataTable Data="_job.Schedules" TData="Schedule" ShowToolbar="false" ShowPagination="false">
                    <Columns>
                        <BbDataTableColumn TData="Schedule" TValue="string" Property="@(x => x.Name)" Header="Schedule Name"></BbDataTableColumn>
                        <BbDataTableColumn TData="Schedule" TValue="string" Property="@(x => x.CronExpression)" Header="Frequency">
                            <CellTemplate Context="schedule">
                                @CronHelper.GetDescription(schedule.CronExpression)
                            </CellTemplate>
                        </BbDataTableColumn>
                        <BbDataTableColumn TData="Schedule" TValue="string" Header="Enabled">
                            <CellTemplate Context="schedule">
                                <BbBadge Variant="@(schedule.IsEnabled? BadgeVariant.Default: BadgeVariant.Secondary)">@(schedule.IsEnabled ? "Enabled" : "Disabled")</BbBadge>
                            </CellTemplate>
                        </BbDataTableColumn>
                        <BbDataTableColumn TData="Schedule" TValue="string" Header="Actions">
                            <CellTemplate Context="schedule">
                                <BbButton Variant="ButtonVariant.Destructive" Size="ButtonSize.Small" OnClick="() => RemoveJobSchedule(schedule.Id)" Loading="_removingScheduleId == schedule.Id">
                                    <Icon>
                                        <LucideIcon Name="trash" Class="h-4 w-4" />
                                    </Icon>
                                    <ChildContent>Remove</ChildContent>
                                </BbButton>
                            </CellTemplate>
                        </BbDataTableColumn>
                    </Columns>
                </BbDataTable>
            </BbCardContent>
        </BbCard>
    </div>
    <BbAccordion Collapsible>
        <BbCard Class="mt-3">
            <BbCardContent>
                <BbAccordionItem Value="job-steps">
                    <BbAccordionTrigger>Steps</BbAccordionTrigger>
                    <BbAccordionContent>
                        @if (_editingSteps)
                        {
                            <div class="flex flex-col gap-2 mb-3">
                                @for (var i = 0; i < _editSteps.Count; i++)
                                {
                                    var idx = i;
                                    <div class="flex items-center gap-2">
                                        <span class="text-sm text-muted-foreground w-6 shrink-0">@(idx + 1).</span>
                                        <BbInputField TValue="string" @bind-Value="_editSteps[idx].Name"
                                                      Placeholder="Step name..." Class="w-40 shrink-0" />
                                        <BbCombobox TValue="long"
                                                    Options="_executableSelectOptions"
                                                    @bind-Value="_editSteps[idx].SelectedExecutableId"
                                                    Placeholder="Select executable..."
                                                    MatchTriggerWidth
                                                    Class="flex-1" />
                                        <div class="flex gap-1">
                                            <BbButton Variant="ButtonVariant.Ghost" Size="ButtonSize.Icon"
                                                      OnClick="() => MoveStepUp(idx)" Disabled="idx == 0" Type="ButtonType.Button">
                                                <LucideIcon Name="chevron-up" Class="h-4 w-4" />
                                            </BbButton>
                                            <BbButton Variant="ButtonVariant.Ghost" Size="ButtonSize.Icon"
                                                      OnClick="() => MoveStepDown(idx)" Disabled="idx == _editSteps.Count - 1" Type="ButtonType.Button">
                                                <LucideIcon Name="chevron-down" Class="h-4 w-4" />
                                            </BbButton>
                                            <BbButton Variant="ButtonVariant.Ghost" Size="ButtonSize.Icon"
                                                      OnClick="() => RemoveEditStep(idx)" Type="ButtonType.Button">
                                                <LucideIcon Name="trash-2" Class="h-4 w-4 text-destructive" />
                                            </BbButton>
                                        </div>
                                    </div>
                                }
                            </div>
                            <div class="flex gap-2">
                                <BbButton Variant="ButtonVariant.Outline" Size="ButtonSize.Small" OnClick="AddEditStep" Type="ButtonType.Button">
                                    <Icon><LucideIcon Name="plus" Class="h-3 w-3" /></Icon>
                                    <ChildContent>Add Step</ChildContent>
                                </BbButton>
                                <BbButton Size="ButtonSize.Small" OnClick="SaveSteps" Loading="_savingSteps">
                                    <Icon><LucideIcon Name="save" Class="h-4 w-4" /></Icon>
                                    <ChildContent>Save</ChildContent>
                                </BbButton>
                                <BbButton Variant="ButtonVariant.Ghost" Size="ButtonSize.Small" OnClick="CancelEditSteps">Cancel</BbButton>
                            </div>
                        }
                        else
                        {
                            <BbAccordion Collapsible>
                                @foreach (var step in _job.Steps.OrderBy(s => s.StepNumber))
                                {
                                    var stepItems = _stepParameterItems.TryGetValue(step.Id, out var items) ? items : [];
                                    <div class="border rounded-md mb-2">
                                        <BbAccordionItem Value="@($"step-{step.Id}")">
                                            <BbAccordionTrigger>
                                                <span class="font-medium">Step @step.StepNumber — @step.Name</span>
                                                <span class="text-muted-foreground ml-2">(@step.ExecutableName)</span>
                                            </BbAccordionTrigger>
                                            <BbAccordionContent>
                                                @if (stepItems.Count == 0)
                                                {
                                                    <p class="text-sm text-muted-foreground py-1">No parameters defined for this executable.</p>
                                                }
                                                else
                                                {
                                                    <BbDataTable Data="stepItems" TData="JobParameterDisplayItem" ShowToolbar="false" ShowPagination="false">
                                                        <Columns>
                                                            <BbDataTableColumn TData="JobParameterDisplayItem" TValue="string" Property="x => x.Key" Header="Name" />
                                                            <BbDataTableColumn TData="JobParameterDisplayItem" TValue="string" Property="@(x => x.Description ?? "-")" Header="Description" />
                                                            <BbDataTableColumn TData="JobParameterDisplayItem" TValue="string" Property="x => x.Type" Header="Type" />
                                                            <BbDataTableColumn TData="JobParameterDisplayItem" TValue="string" Property="@(x => x.Value ?? "-")" Header="Value" />
                                                            <BbDataTableColumn TData="JobParameterDisplayItem" TValue="bool" Property="x => x.IsRequired" Header="Required?" />
                                                            <BbDataTableColumn TData="JobParameterDisplayItem" TValue="string" Header="Actions">
                                                                <CellTemplate>
                                                                    <EditJobParameterModal Item="context" OnParameterEdited="StateHasChanged" />
                                                                </CellTemplate>
                                                            </BbDataTableColumn>
                                                            <BbDataTableColumn TData="JobParameterDisplayItem" TValue="bool" Header="">
                                                                <CellTemplate>
                                                                    @if (!context.IsExecutableParameter)
                                                                    {
                                                                        <LucideIcon Name="triangle-alert" Class="h-4 w-4" Color="#FFFF00" />
                                                                    }
                                                                </CellTemplate>
                                                            </BbDataTableColumn>
                                                        </Columns>
                                                    </BbDataTable>
                                                }
                                            </BbAccordionContent>
                                        </BbAccordionItem>
                                    </div>
                                }
                            </BbAccordion>
                            <BbButton Variant="ButtonVariant.Outline" Size="ButtonSize.Small" Class="mt-3" OnClick="StartEditSteps">
                                <Icon><LucideIcon Name="pencil" Class="h-4 w-4" /></Icon>
                                <ChildContent>Edit Steps</ChildContent>
                            </BbButton>
                        }
                    </BbAccordionContent>
                </BbAccordionItem>
            </BbCardContent>
        </BbCard>
        <BbCard Class="mt-3">
            <BbCardContent>
                <BbAccordionItem Value="job-runs">
                    <BbAccordionTrigger>Job Runs</BbAccordionTrigger>
                    <BbAccordionContent>
                        <BbDataTable Data="_runs" TData="JobRun" ShowToolbar="false">
                            <Columns>
                                <BbDataTableColumn TData="JobRun" TValue="string" Property="x => x.Trigger" Header="Trigger" />
                                <BbDataTableColumn TData="JobRun" TValue="DateTime" Property="x => x.StartedAt.ToLocalTime()" Header="Started At" />
                                <BbDataTableColumn TData="JobRun" TValue="DateTime?" Property="x => x.FinishedAt" Header="Duration">
                                    <CellTemplate Context="run">
                                        @(run.FinishedAt.HasValue ? (run.FinishedAt.Value - run.StartedAt).Humanize() : "-")
                                    </CellTemplate>
                                </BbDataTableColumn>
                                <BbDataTableColumn TData="JobRun" TValue="string" Property="x => x.Status" Header="Status">
                                    <CellTemplate Context="run">
                                        <BbBadge
                                            Variant="@(run.Status switch
                                            {
                                                "Failed" or "Stopped" => BadgeVariant.Destructive,
                                                "Running" => BadgeVariant.Secondary,
                                                _ => BadgeVariant.Default
                                            })">@run.Status</BbBadge>
                                    </CellTemplate>
                                </BbDataTableColumn>
                                <BbDataTableColumn TData="JobRun" TValue="string" Header="Actions">
                                    <CellTemplate Context="run">
                                        <BbButton Size="ButtonSize.Small" Variant="ButtonVariant.Outline" OnClick="() => NavigateToRunDetail(run.Id)">
                                            <Icon>
                                                <LucideIcon Name="eye" Class="h-4 w-4" />
                                            </Icon>
                                            <ChildContent>View</ChildContent>
                                        </BbButton>
                                    </CellTemplate>
                                </BbDataTableColumn>
                            </Columns>
                        </BbDataTable>
                    </BbAccordionContent>
                </BbAccordionItem>
            </BbCardContent>
        </BbCard>
    </BbAccordion>

    @if (UnsavedChangeCount > 0)
    {
        <div class="unsaved-changes-bar">
            <LucideIcon Name="save" Class="h-4 w-4 shrink-0" />
            <span>You have <strong>@UnsavedChangeCount</strong> unsaved changes</span>
            <BbButton Size="ButtonSize.Small" OnClick="SaveAllStepParameters" Loading="_savingParameters">
                <Icon>
                    <LucideIcon Name="save" Class="h-4 w-4" />
                </Icon>
                <ChildContent>
                    @(_savingParameters ? "Saving…" : "Save Changes")
                </ChildContent>
            </BbButton>
        </div>
    }
}

@code {
    [Parameter]
    public long Id { get; set; }

    private SSAReplacement.Wasm.Client.Jobs.JobDetail _job = null!;
    private List<JobRun> _runs = [];

    // Per-step parameter display items: stepId -> display items
    private Dictionary<long, List<JobParameterDisplayItem>> _stepParameterItems = new();
    // Per-step original values for unsaved-changes tracking: stepId -> (key -> value)
    private Dictionary<long, Dictionary<string, string?>> _originalStepParameterValues = new();

    private bool _savingParameters;
    private bool _triggeringJob;
    private bool _togglingEnabled;
    private long? _removingScheduleId;

    private bool _loading = true;
    private string? _error;
    private bool _hasError => !string.IsNullOrEmpty(_error);

    private List<Executable> _executables = [];
    private List<SelectOption<long>> _executableSelectOptions => _executables.Select(e => new SelectOption<long>(e.Id, e.Name)).ToList();

    private bool _editingSteps;
    private List<StepEditState> _editSteps = [];
    private bool _savingSteps;

    private int UnsavedChangeCount => _stepParameterItems.Sum(kvp =>
    {
        if (!_originalStepParameterValues.TryGetValue(kvp.Key, out var originals))
            return 0;
        return kvp.Value.Count(item => originals.TryGetValue(item.Key, out var orig) && item.Value != orig);
    });

    protected override async Task OnInitializedAsync() => await LoadData();

    protected override void OnParametersSet()
    {
        Breadcrumbs.Set(
            new BreadcrumbItem() { Text = "Jobs", Url = "/jobs" },
            new BreadcrumbItem() { Text = "Job Detail" }
        );
    }

    private async Task LoadData()
    {
        try
        {
            var jobTask = Api.Job.GetJobAsync(Id);
            var runTask = Api.Job.GetJobRunsAsync(Id);
            var executablesTask = Api.Executable.GetExecutablesAsync();

            var job = await jobTask;
            if (job is null)
            {
                _error = "Job not found.";
                return;
            }

            _job = job;
            _executables = await executablesTask;
            _runs = await runTask;

            _stepParameterItems = new();
            _originalStepParameterValues = new();

            foreach (var step in job.Steps)
            {
                var exe = _executables.FirstOrDefault(e => e.Id == step.ExecutableId);
                var exeParameters = exe is not null
                    ? await Api.Executable.GetExecutableVersionParametersAsync(exe.Id, exe.ActiveVersion)
                    : [];

                var savedParams = step.Parameters;

                var savedParamsLookup = savedParams.GroupJoin(exeParameters, jp => jp.Key, xp => xp.Name, (jp, xp) => new { jp, xp })
                    .SelectMany(x => x.xp.DefaultIfEmpty(), (x, xp) => new JobParameterDisplayItem(x.jp, xp));

                var exeParamsLookup = exeParameters.GroupJoin(savedParams, xp => xp.Name, jp => jp.Key, (xp, jp) => new { xp, jp })
                    .SelectMany(x => x.jp.DefaultIfEmpty(), (x, jp) => new JobParameterDisplayItem(jp, x.xp));

                var displayItems = savedParamsLookup.Union(exeParamsLookup)
                    .DistinctBy(x => x.Key)
                    .OrderByDescending(x => x.IsExecutableParameter)
                    .ThenBy(x => x.Key)
                    .ToList();

                _stepParameterItems[step.Id] = displayItems;
                _originalStepParameterValues[step.Id] = displayItems.ToDictionary(x => x.Key, x => x.Value);
            }
        }
        catch (Exception e)
        {
            _error = $"Error loading job: {e.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task TriggerJobRun()
    {
        _triggeringJob = true;
        try
        {
            await Api.Job.TriggerJobAsync(Id);
            Toasts.Success("Job triggered successfully");
            _runs = await Api.Job.GetJobRunsAsync(Id);
        }
        catch (Exception)
        {
            Toasts.Error("An error occurred while triggering the job");
        }
        finally
        {
            _triggeringJob = false;
        }
    }

    private async Task ToggleEnabled()
    {
        _togglingEnabled = true;
        try
        {
            await Api.Job.UpdateJobAsync(Id, new UpdateJobRequest(_job.Name, !_job.IsEnabled, _job.NotifyEmail));
            var wasEnabled = _job.IsEnabled;
            await LoadJob();
            Toasts.Success($"Job {(wasEnabled ? "disabled" : "enabled")} successfully");
        }
        catch (Exception)
        {
            Toasts.Error("An error occured while updating the job");
        }
        finally
        {
            _togglingEnabled = false;
        }
    }

    private async Task LoadJob()
    {
        try
        {
            var job = await Api.Job.GetJobAsync(Id);

            if (job is not null)
                _job = job;
        }
        catch (Exception)
        {
            Toasts.Error("An error occurred while reloading job details");
        }
    }

    private async Task RemoveJobSchedule(long jobScheduleId)
    {
        _removingScheduleId = jobScheduleId;
        try
        {
            await Api.Job.SetJobSchedulesAsync(_job.Id, _job.Schedules.Select(x => x.Id).Where(x => x != jobScheduleId));
            Toasts.Success("Job schedule removed successfully");

            await LoadJob();
        }
        catch (Exception)
        {
            Toasts.Error("An error occurred while removing the job schedule");
        }
        finally
        {
            _removingScheduleId = null;
        }
    }

    private async Task SaveAllStepParameters()
    {
        _savingParameters = true;
        try
        {
            foreach (var (stepId, items) in _stepParameterItems)
            {
                if (!_originalStepParameterValues.TryGetValue(stepId, out var originals))
                    continue;

                var hasChanges = items.Any(item => originals.TryGetValue(item.Key, out var orig) && item.Value != orig);
                if (!hasChanges)
                    continue;

                Dictionary<string, string?> parameters = items
                    .Where(x => x.Value is not null)
                    .ToDictionary(x => x.Key, x => x.Value);

                await Api.Job.SetJobStepParametersAsync(Id, stepId, parameters);
            }

            await LoadData();
            Toasts.Success("Job parameters were saved successfully");
        }
        catch (HttpRequestException)
        {
            Toasts.Error("An error occurred while saving job parameters");
        }
        finally
        {
            _savingParameters = false;
        }
    }

    private void StartEditSteps()
    {
        _editSteps = _job.Steps.OrderBy(s => s.StepNumber)
            .Select(s => new StepEditState { SelectedExecutableId = s.ExecutableId, Name = s.Name })
            .ToList();
        _editingSteps = true;
    }

    private void CancelEditSteps()
    {
        _editingSteps = false;
        _editSteps = [];
    }

    private void AddEditStep() => _editSteps.Add(new StepEditState());

    private void RemoveEditStep(int index) => _editSteps.RemoveAt(index);

    private void MoveStepUp(int index)
    {
        if (index <= 0) return;
        (_editSteps[index], _editSteps[index - 1]) = (_editSteps[index - 1], _editSteps[index]);
    }

    private void MoveStepDown(int index)
    {
        if (index >= _editSteps.Count - 1) return;
        (_editSteps[index], _editSteps[index + 1]) = (_editSteps[index + 1], _editSteps[index]);
    }

    private async Task SaveSteps()
    {
        if (_editSteps.Count == 0)
        {
            Toasts.Error("At least one step is required.");
            return;
        }

        if (_editSteps.Any(s => s.SelectedExecutableId == 0))
        {
            Toasts.Error("Please select an executable for each step.");
            return;
        }

        if (_editSteps.Any(s => string.IsNullOrWhiteSpace(s.Name)))
        {
            Toasts.Error("Please enter a name for each step.");
            return;
        }

        _savingSteps = true;
        try
        {
            var steps = _editSteps
                .Select((s, i) => new JobStepRequest(s.SelectedExecutableId, i + 1, s.Name))
                .ToList();

            await Api.Job.SetJobStepsAsync(Id, steps);
            await LoadData();
            _editingSteps = false;
            Toasts.Success("Steps saved successfully");
        }
        catch (Exception)
        {
            Toasts.Error("An error occurred while saving steps");
        }
        finally
        {
            _savingSteps = false;
        }
    }

    private void NavigateToRunDetail(long runId)
    {
        Nav.NavigateTo($"/jobs/{Id}/runs/{runId}");
    }

    private class StepEditState
    {
        public long SelectedExecutableId { get; set; }
        public string Name { get; set; } = "";
    }
}

@using System.ComponentModel.DataAnnotations
@using System.IO.Compression

<BbDialog @bind-Open="isOpen">
    <BbDialogTrigger>
        <BbButton Size="ButtonSize.Small">
            <Icon>
                <LucideIcon Name="upload" Class="h-4 w-4" />
            </Icon>
            <ChildContent>Upload Executable</ChildContent>
        </BbButton>
    </BbDialogTrigger>
    <BbDialogContent>
        <BbDialogHeader>
            <BbDialogTitle>Upload an executable</BbDialogTitle>
        </BbDialogHeader>
        <EditForm EditContext="_editContext" OnValidSubmit="SubmitAddExecutable" id="add-executable-form">
            <DataAnnotationsValidator />

            <BbField>
                <BbFieldLabel For="executable-name">Name</BbFieldLabel>
                <BbInputField TValue="string" @bind-Value="_formState.Name" Id="executable-name" />
                <ValidationMessage For="() => _formState.Name" />
            </BbField>

            <BbFileUpload MaxFileCount="1" Accept=".zip" Class="mt-4" @bind-Files="_formState.SelectedFile" @bind-Files:after="OnFileChanged" />
            <ValidationMessage For="() => _formState.SelectedFile" class="mt-2 validation-message" />

            @if (_noExeError is not null)
            {
                <p class="mt-2 validation-message">@_noExeError</p>
            }
            else if (_detectedExes is not null && _detectedExes.Count > 1)
            {
                <BbField Class="mt-4">
                    <BbFieldLabel>Entry Point Executable</BbFieldLabel>
                    <BbSelect TValue="string"
                              @bind-Value="_selectedExe"
                              Options="_exeOptions"
                              Placeholder="Select an executable..." />
                </BbField>
            }
            else if (_selectedExe is not null)
            {
                <p class="mt-2 text-sm text-muted-foreground">Entry point: <span class="font-mono">@_selectedExe</span></p>
            }

            @if (_noDllError is not null)
            {
                <p class="mt-1 validation-message">@_noDllError</p>
            }
        </EditForm>
        <BbDialogFooter>
            <BbButton Type="ButtonType.Submit" form="add-executable-form" Loading="_submitting" Size="ButtonSize.Small">
                <Icon>
                    <LucideIcon Name="plus" Class="h-4 w-4" />
                </Icon>
                <ChildContent>Add</ChildContent>
            </BbButton>
        </BbDialogFooter>
    </BbDialogContent>
</BbDialog>

@code {

    [Inject]
    public required SsaApiClient Api { get; set; }

    [Inject]
    public required ToastService Toasts { get; set; }

    [Parameter]
    public EventCallback OnExecutableCreated { get; set; }

    private AddExecutableFormState _formState = null!;
    private EditContext _editContext = null!;
    private ValidationMessageStore _validationMessageStore = null!;

    private bool isOpen = false;
    private bool _submitting;

    private List<string>? _detectedExes;
    private List<SelectOption<string>>? _exeOptions;
    private string? _selectedExe;
    private string? _noExeError;
    private string? _noDllError;

    private const long MaxAllowedFileSize = 1024 * 1024 * 10;

    protected override void OnParametersSet()
    {
        _formState = new();
        _editContext = new(_formState);

        _editContext.OnFieldChanged += (sender, args) =>
        {
            _validationMessageStore.Clear(args.FieldIdentifier);
        };

        _validationMessageStore = new(_editContext);
    }

    private async Task OnFileChanged()
    {
        _detectedExes = null;
        _exeOptions = null;
        _selectedExe = null;
        _noExeError = null;
        _noDllError = null;

        if (_formState.SelectedFile is not { Count: 1 })
            return;

        var selectedFile = _formState.SelectedFile[0];

        using var memoryStream = new MemoryStream();
        await selectedFile.File.OpenReadStream(MaxAllowedFileSize).CopyToAsync(memoryStream);

        using var zip = new ZipArchive(memoryStream, ZipArchiveMode.Read);
        var exeNames = zip.Entries
            .Select(e => e.Name)
            .Where(n => n.EndsWith(".exe", StringComparison.OrdinalIgnoreCase))
            .ToList();

        if (exeNames.Count == 0)
        {
            _noExeError = "No executables (.exe) found in this zip file.";
            return;
        }

        _detectedExes = exeNames;
        _exeOptions = exeNames.Select(SelectOption.FromValue).ToList();

        if (exeNames.Count == 1)
            _selectedExe = exeNames[0];
    }

    private async Task SubmitAddExecutable()
    {
        _noDllError = null;

        if (_selectedExe is null)
        {
            _noExeError = "Please select an entry point executable.";
            return;
        }

        var selectedFile = _formState.SelectedFile[0];

        using var memoryStream = new MemoryStream();
        await selectedFile.File.OpenReadStream(MaxAllowedFileSize).CopyToAsync(memoryStream);

        using var zip = new ZipArchive(memoryStream, ZipArchiveMode.Read);

        var expectedDll = Path.ChangeExtension(_selectedExe, ".dll");
        if (!zip.Entries.Select(e => e.Name).Contains(expectedDll, StringComparer.OrdinalIgnoreCase))
        {
            _noDllError = $"A matching DLL ({expectedDll}) must exist in the zip for parameter scanning.";
            return;
        }

        _submitting = true;
        try
        {
            var executable = await Api.Executable.CreateExecutableAsync(_formState.Name);

            await using var fileStream = selectedFile.File.OpenReadStream(MaxAllowedFileSize);
            var version = await Api.Executable.UploadExecutableVersionAsync(executable.Id, fileStream, selectedFile.Name, _selectedExe);

            await Api.Executable.ActivateExecutableVersionAsync(executable.Id, version.Id);

            if (OnExecutableCreated.HasDelegate)
            {
                await OnExecutableCreated.InvokeAsync();
            }

            Toasts.Success("Executable uploaded successfully");
            isOpen = false;

            await InvokeAsync(StateHasChanged);
        }
        catch (Exception e)
        {
            Toasts.Error("Failed to upload executable: " + e.Message);
            Console.WriteLine(e.ToString());
            //TODO Rollback if any API calls error
        }
        finally
        {
            _submitting = false;
        }
    }

    private record AddExecutableFormState
    {
        [Required(ErrorMessage = "Please choose a name for the executable.")]
        public string Name { get; set; } = "";

        [Length(1, 1, ErrorMessage = "Please choose a zip file.")]
        public IReadOnlyList<FileUploadItem> SelectedFile { get; set; } = [];
    }
}

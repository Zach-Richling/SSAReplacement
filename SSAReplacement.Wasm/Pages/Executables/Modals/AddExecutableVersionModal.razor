@using System.ComponentModel.DataAnnotations
@using System.IO.Compression

<BbDialog @bind-Open="isOpen">
    <BbDialogTrigger>
        <BbButton Size="ButtonSize.Small">
            <Icon>
                <LucideIcon Name="upload" Class="h-4 w-4" />
            </Icon>
            <ChildContent>Upload Executable Version</ChildContent>
        </BbButton>
    </BbDialogTrigger>
    <BbDialogContent>
        <BbDialogHeader>
            <BbDialogTitle>Upload an executable version</BbDialogTitle>
        </BbDialogHeader>
        <EditForm EditContext="_editContext" OnValidSubmit="SubmitAddExecutableVersion" id="add-executable-version-form">
            <DataAnnotationsValidator />

            <BbField Class="mt-4">
                <BbFieldLabel For="executable-entrypoint">Entrypoint Dll</BbFieldLabel>
                <BbInputField TValue="string" @bind-Value="_formState.EntryPointDll" Id="executable-entrypoint" />
                <ValidationMessage For="() => _formState.EntryPointDll" />
            </BbField>

            <BbFileUpload MaxFileCount="1" Accept=".zip" Class="mt-4" @bind-Files="_formState.SelectedFile" />
            <ValidationMessage For="() => _formState.SelectedFile" class="mt-2 validation-message" />

        </EditForm>
        <BbDialogFooter>
            <BbButton Type="ButtonType.Submit" form="add-executable-version-form" Loading="_submitting" Size="ButtonSize.Small">
                <Icon>
                    <LucideIcon Name="plus" Class="h-4 w-4" />
                </Icon>
                <ChildContent>Add</ChildContent>
            </BbButton>
        </BbDialogFooter>
    </BbDialogContent>
</BbDialog>

@code {

    [Inject]
    public required SsaApiClient Api { get; set; }

    [Inject]
    public required ToastService Toasts { get; set; }

    [Parameter]
    public EventCallback OnExecutableVersionCreated { get; set; }

    [Parameter]
    public required ExecutableDetail Executable { get; set; }

    private AddExecutableVersionFormState _formState = null!;
    private EditContext _editContext = null!;
    private ValidationMessageStore _validationMessageStore = null!;

    private bool isOpen = false;
    private bool _submitting;

    private const long MaxAllowedFileSize = 1024 * 1024 * 10;

    protected override void OnParametersSet()
    {
        _formState = new();
        _editContext = new(_formState);

        _editContext.OnFieldChanged += (sender, args) =>
        {
            _validationMessageStore.Clear(args.FieldIdentifier);
        };

        _validationMessageStore = new(_editContext);
    }

    private async Task SubmitAddExecutableVersion()
    {
        long? executableVersionId;

        _submitting = true;
        try
        {
            var selectedFile = _formState.SelectedFile[0];

            using var memoryStream = new MemoryStream();
            await selectedFile.File.OpenReadStream(MaxAllowedFileSize).CopyToAsync(memoryStream);

            //We need a seekable stream to check the contents of the zip file
            using var zip = new ZipArchive(memoryStream, ZipArchiveMode.Read);

            var fieldId = new FieldIdentifier(_formState, nameof(_formState.EntryPointDll));
            _validationMessageStore.Clear(fieldId);

            //Verify the entry point dll is in the zip file
            if (!zip.Entries.Select(x => x.Name).Contains(_formState.EntryPointDll))
            {
                _validationMessageStore.Add(fieldId, "This Dll is not in the zip file.");
                _editContext.NotifyValidationStateChanged();
                return;
            }

            memoryStream.Seek(0, SeekOrigin.Begin);

            //Grabbing a new stream so the old one can be disposed to minimize memory usage
            await using var fileStream = selectedFile.File.OpenReadStream(MaxAllowedFileSize);
            var version = await Api.Executable.UploadExecutableVersionAsync(Executable.Id, fileStream, selectedFile.Name, _formState.EntryPointDll);
            executableVersionId = version.Id;

            if (OnExecutableVersionCreated.HasDelegate)
            {
                await OnExecutableVersionCreated.InvokeAsync();
            }

            Toasts.Success("Executable version uploaded successfully");
            isOpen = false;

            await InvokeAsync(StateHasChanged);
        }
        catch (Exception e)
        {
            Toasts.Error("Failed to upload executable version: " + e.Message);
            Console.WriteLine(e.ToString());
            //TODO Rollback if any API calls error
        }
        finally
        {
            _submitting = false;
        }
    }

    private record AddExecutableVersionFormState
    {
        [Length(1, 1, ErrorMessage = "Please choose a zip file.")]
        public IReadOnlyList<FileUploadItem> SelectedFile { get; set; } = [];

        [Required(ErrorMessage = "Please choose an entrypoint for the executable.")]
        [RegularExpression(@".+\.dll", ErrorMessage = "Make sure the selected file is a dll.")]
        public string EntryPointDll { get; set; } = "";
    }
}

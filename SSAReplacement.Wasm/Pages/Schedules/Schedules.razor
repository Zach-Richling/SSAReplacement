@page "/schedules"
@using SSAReplacement.Wasm.Pages.Schedules.Modals

@inject SsaApiClient Api
@inject BreadcrumbService Breadcrumbs
@inject ToastService Toasts

<PageTitle>Schedules</PageTitle>

<div class="flex flex-row justify-between items-center">
    <h1 class="text-lg font-semibold m-0">Schedules</h1>
    <div class="flex items-center flex-1" style="max-width: 20rem;">
        <SearchBar @bind-Value="_searchQuery" AriaLabel="Filter schedules by name" />
    </div>
    <AddScheduleModal OnScheduleCreated="LoadData" />
</div>

@if (_error is not null)
{
    <BbAlert Variant="AlertVariant.Danger" Class="mt-4">@_error</BbAlert>
}

<BbDataTable Data="_filteredSchedules" TData="Schedule" ShowToolbar="false" Class="mt-4" IsLoading="_loading">
    <Columns>
        <BbDataTableColumn TData="Schedule" TValue="string" Property="@(x => x.Name)" Header="Name"></BbDataTableColumn>
        <BbDataTableColumn TData="Schedule" TValue="string" Property="@(x => CronHelper.GetDescription(x.CronExpression))" Header="Frequency" />
        <BbDataTableColumn TData="Schedule" TValue="bool" Property="@(x => x.IsEnabled)" Header="Enabled">
            <CellTemplate>
                <BbBadge Variant="@(context.IsEnabled ? BadgeVariant.Default: BadgeVariant.Secondary)">@(context.IsEnabled ? "Enabled" : "Disabled")</BbBadge>
            </CellTemplate>
        </BbDataTableColumn>
        <BbDataTableColumn TData="Schedule" TValue="string" Property="@(x => x.CreatedAt.ToTimeAgo())" Header="Created" />
        <BbDataTableColumn TData="Schedule" TValue="string" Header="Actions">
            <CellTemplate>
                <BbButton Variant="@(context.IsEnabled? ButtonVariant.Secondary: ButtonVariant.Default)" Size="ButtonSize.Small" OnClick="() => ToggleEnabled(context)" Loading="_togglingSchedule == context" >
                    <Icon>
                        @if (context.IsEnabled)
                        {
                            <LucideIcon Name="power-off" Class="h-4 w-4" />
                        }
                        else
                        {
                            <LucideIcon Name="power" Class="h-4 w-4" />
                        }
                    </Icon>
                    <ChildContent>
                        @(context.IsEnabled ? "Disable" : "Enable")
                    </ChildContent>
                </BbButton>
            </CellTemplate>
        </BbDataTableColumn>
    </Columns>
    <EmptyTemplate>
        <tr class="flex flex-row justify-center">
            <td colspan="5" class="p-4 text-center text-muted">No schedules found.</td>
        </tr>
    </EmptyTemplate>
</BbDataTable>

@code {
    private List<Schedule> _schedules = [];
    private string _searchQuery = "";

    private bool _loading = true;
    private string? _error;
    private Schedule? _togglingSchedule;

    private IEnumerable<Schedule> _filteredSchedules =>
        string.IsNullOrWhiteSpace(_searchQuery)
            ? _schedules
            : _schedules.Where(s => s.Name.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        Breadcrumbs.Set(new BreadcrumbItem() { Text = "Schedules" });
        await LoadData();
    }

    private async Task LoadData()
    {
        _loading = true;
        _error = null;

        try
        {
            _schedules = await Api.Schedule.GetSchedulesAsync();
        }
        catch (Exception ex)
        {
            _error = "Failed to load: " + ex.Message;
            _schedules = [];
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task ToggleEnabled(Schedule schedule)
    {
        _togglingSchedule = schedule;
        try
        {
            await Task.Delay(5000);
            await Api.Schedule.UpdateScheduleAsync(schedule.Id, new UpdateScheduleRequest(schedule.Name, schedule.CronExpression, !schedule.IsEnabled));
            schedule.IsEnabled = !schedule.IsEnabled;
            Toasts.Success($"Schedule {(schedule.IsEnabled ? "enabled" : "disabled")} successfully");
        } 
        catch (Exception)
        {
            Toasts.Error("There was an error while updating the schedule");
        }
        finally
        {
            _togglingSchedule = null;
        }
    }
}
